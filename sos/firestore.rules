rules_version = '2';

// ==========================================
// FIRESTORE DATABASE RULES - SOS-EXPAT
// ==========================================
service cloud.firestore {
  match /databases/{database}/documents {

    // ================= HELPER FUNCTIONS =================
    function isAuthenticated() {
      return request.auth != null;
    }

    // Vérifie si l'utilisateur est admin via:
    // 1. Custom claims Firebase Auth (request.auth.token.role)
    // 2. OU le document Firestore users/{uid}.role
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isProvider() {
      return request.auth != null &&
             (request.auth.token.role == 'lawyer' || request.auth.token.role == 'expat');
    }

    function isClient() {
      return request.auth != null && request.auth.token.role == 'client';
    }

    // Finance admin: admin avec acces aux donnees financieres
    function isFinanceAdmin() {
      return isAdmin();
    }

    // Expert-comptable: acces lecture seule aux donnees financieres
    function isAccountant() {
      return isAuthenticated() && request.auth.token.accountant == true;
    }

    // Lecteur finance: admin OU expert-comptable
    function isFinanceReader() {
      return isFinanceAdmin() || isAccountant();
    }

    // Vérifie si l'utilisateur est agency_manager (pour dashboard multi-prestataire)
    function isAgencyManager() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'agency_manager';
    }

    // Vérifie si l'utilisateur est agency_manager avec accès au provider
    function hasAgencyAccessToProvider(providerId) {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'agency_manager' ||
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') &&
             providerId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.linkedProviderIds;
    }

    // Super admin: admin avec tous les droits
    function isSuperAdmin() {
      return isAdmin();
    }

    // ================= USERS COLLECTION =================
    // P0 SECURITY FIX: Protection des champs de privilèges contre l'escalade
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Création : propriétaire OU admin/dev (pour les profils AAA)
      allow create: if (isAuthenticated() && isOwner(userId) &&
                    // Empêcher la création avec des rôles admin/dev par les utilisateurs normaux
                    // Roles autorisés: client, lawyer, expat, chatter, blogger, influencer, groupAdmin
                    (!request.resource.data.keys().hasAny(['role']) ||
                     request.resource.data.role in ['client', 'lawyer', 'expat', 'chatter', 'blogger', 'influencer', 'groupAdmin']))
                    || isAdmin();
      // L'utilisateur peut modifier ses propres données SAUF:
      // - role, isApproved, approvalStatus: empêche l'escalade de privilèges
      // - isBanned, bannedAt, bannedReason: empêche la désactivation du ban
      // - forcedAiAccess, freeTrialUntil: empêche l'accès gratuit non autorisé
      // - stripeCustomerId: protège l'intégrité financière
      // - payoutMode, aaaPayoutMode, isAAA: protège le routage des paiements (admin-only)
      // - affiliateCode, referredBy, capturedRates: champs d'affiliation immutables
      // - totalEarned, availableBalance, pendingBalance: balances gérées par CF
      // - affiliateStatus, affiliateStats: statuts gérés par système
      allow update: if (isOwner(userId) &&
                        !request.resource.data.diff(resource.data).affectedKeys()
                          .hasAny(['role', 'isApproved', 'approvalStatus', 'isBanned',
                                   'bannedAt', 'bannedReason', 'forcedAiAccess',
                                   'forceAiAccess', 'forcedAIAccess', 'freeTrialUntil',
                                   'freeTrialGrantedBy', 'stripeCustomerId',
                                   'payoutMode', 'aaaPayoutMode', 'isAAA', 'aaaBusySimulatedAt', 'aaaPreviousAvailability',
                                   'affiliateCode', 'referredBy', 'referredByUserId',
                                   'capturedRates', 'lockedRates',
                                   'commissionPlanId', 'commissionPlanName', 'rateLockDate',
                                   'totalEarned', 'availableBalance',
                                   'pendingBalance', 'affiliateStatus', 'affiliateStats',
                                   'linkedProviderIds', 'shareBusyStatus']))
                       || isAdmin();
      allow delete: if isAdmin();
    }

    // ================= SOS_PROFILES COLLECTION =================
    // P0 SECURITY: Les IDs Stripe/PayPal ne doivent JAMAIS être exposés côté client
    // Ces champs sont gérés uniquement par Cloud Functions via Admin SDK
    match /sos_profiles/{profileId} {
      // P0 SECURITY: Les IDs Stripe/PayPal ne doivent JAMAIS être exposés côté client
      // Ces champs sont gérés uniquement par Cloud Functions via Admin SDK
      // NOTE: stripeAccountId, paypalMerchantId ne sont pas inclus dans les projections frontend
      // P1-6 SECURITY FIX: Restreindre la lecture aux profils visibles ou au propriétaire
      // Empêche l'énumération de tous les providers et protège les données sensibles
      // AJOUT 2026-02-12: Les agency_managers peuvent lire les profils de leurs providers liés
      allow read: if resource.data.isVisible == true
                  || (isAuthenticated() && request.auth.uid == profileId)
                  || isAdmin()
                  || hasAgencyAccessToProvider(profileId);

      // Écriture : propriétaire ou admin
      // NOTE: On ne peut pas utiliser isProvider() ici car les custom claims
      // ne sont définis qu'APRÈS la création du profil (via onProviderCreated trigger)
      // Le propriétaire NE PEUT PAS modifier les champs financiers sensibles
      // Admin/Dev peuvent créer des profils AAA (profils gérés en interne)
      allow create: if (isAuthenticated() && isOwner(profileId) &&
                    !request.resource.data.keys().hasAny(['stripeAccountId', 'paypalMerchantId', 'stripeCustomerId']))
                    || isAdmin();
      // P0-1 SECURITY FIX: paypalEmailVerified et paypalEmailVerifiedAt sont protégés
      // pour empêcher un provider de se marquer comme vérifié sans validation email
      // P0 SECURITY: payoutMode, aaaPayoutMode et isAAA sont protégés (admin-only)
      // pour empêcher un provider de rediriger ses paiements
      allow update: if (isOwner(profileId) &&
                        !request.resource.data.diff(resource.data).affectedKeys()
                          .hasAny(['stripeAccountId', 'paypalMerchantId', 'stripeCustomerId',
                                   'totalEarnings', 'totalPayPalEarnings', 'pendingBalance', 'reservedBalance',
                                   'paypalEmailVerified', 'paypalEmailVerifiedAt',
                                   'payoutMode', 'aaaPayoutMode', 'isAAA', 'aaaBusySimulatedAt', 'aaaPreviousAvailability',
                                   'isFeatured', 'featuredAt', 'featuredBy']))
                       || isAdmin();
      allow delete: if isAdmin();

      // Sous-collection reviews
      match /reviews/{reviewId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if isAdmin();
      }
    }

    // ================= REVIEWS COLLECTION =================
    match /reviews/{reviewId} {
      // Lecture : tout le monde pour les avis publiés, admin/dev pour tous
      allow read: if resource.data.status == 'published' && resource.data.isPublic == true
                  || isAdmin()
                 
                  || (isAuthenticated() && resource.data.clientId == request.auth.uid)
                  || (isAuthenticated() && resource.data.providerId == request.auth.uid);

      // Création : client authentifié uniquement
      // Validation : le clientId doit correspondre à l'utilisateur connecté
      allow create: if isAuthenticated()
                    && request.resource.data.clientId == request.auth.uid
                    && request.resource.data.providerId is string
                    && request.resource.data.callId is string
                    && request.resource.data.rating is number
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5
                    && request.resource.data.comment is string
                    && request.resource.data.comment.size() > 0
                    && request.resource.data.comment.size() <= 2000;

      // Mise à jour :
      // - Le prestataire peut modifier isPublic et status (pour show/hide)
      // - Admin peut tout modifier
      allow update: if isAdmin()
                   
                    || (isAuthenticated()
                        && resource.data.providerId == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isPublic', 'status']));

      // Suppression : admin seulement
      allow delete: if isAdmin();
    }

    // ================= REVIEWS_REQUESTS COLLECTION =================
    // Created by Cloud Functions (TwilioCallManager) after a successful call.
    // The owning client must read its own request to render /review/:requestId.
    match /reviews_requests/{requestId} {
      allow read: if isAdmin()
                  || (isAuthenticated() && resource.data.clientId == request.auth.uid);
      // Writes are reserved to Cloud Functions (Admin SDK bypasses rules).
      allow write: if false;
    }

    // ================= CALLS/CALL_SESSIONS COLLECTION =================
    match /calls/{callId} {
      allow read: if isAuthenticated() &&
                  (resource.data.clientId == request.auth.uid ||
                   resource.data.providerId == request.auth.uid ||
                   isAdmin());
      // P1 SECURITY FIX: Validate clientId matches authenticated user
      allow create: if isAuthenticated() &&
                    request.resource.data.clientId == request.auth.uid;
      allow update: if isAuthenticated() &&
                    (resource.data.clientId == request.auth.uid ||
                     resource.data.providerId == request.auth.uid ||
                     isAdmin());
      allow delete: if isAdmin();
    }

    match /call_sessions/{sessionId} {
      // FIX: clientId et providerId sont dans metadata, pas au niveau racine
      // Pour les requêtes avec where(), on vérifie que l'utilisateur demande ses propres sessions
      // NOTE: Les requêtes DOIVENT filtrer par metadata.clientId ou metadata.providerId
      // P0 FIX: Support linkedProviderIds pour accès multi-provider (AiAssistantPageV2)
      allow read: if isAuthenticated() &&
                  (resource.data.metadata.clientId == request.auth.uid ||
                   resource.data.metadata.providerId == request.auth.uid ||
                   // Permettre les requêtes sur clientId au niveau racine (si présent)
                   (resource.data.clientId != null && resource.data.clientId == request.auth.uid) ||
                   (resource.data.providerId != null && resource.data.providerId == request.auth.uid) ||
                   // P0 FIX: Support linkedProviderIds - permet aux utilisateurs liés de lire les sessions
                   (resource.data.providerId != null &&
                    get(/databases/$(database)/documents/users/$(request.auth.uid)).data.linkedProviderIds.hasAny([resource.data.providerId])) ||
                   (resource.data.metadata.providerId != null &&
                    get(/databases/$(database)/documents/users/$(request.auth.uid)).data.linkedProviderIds.hasAny([resource.data.metadata.providerId])) ||
                   isAdmin());
      // Seul le client peut créer une session (validation de l'ownership)
      allow create: if isAuthenticated() &&
                    (request.resource.data.metadata.clientId == request.auth.uid ||
                     request.resource.data.clientId == request.auth.uid);
      // Seuls les participants (client ou provider) peuvent mettre à jour
      // SAUF les champs financiers/statut gérés exclusivement par Cloud Functions
      allow update: if isAuthenticated() &&
                    ((resource.data.metadata.clientId == request.auth.uid ||
                     resource.data.metadata.providerId == request.auth.uid ||
                     resource.data.clientId == request.auth.uid ||
                     resource.data.providerId == request.auth.uid ||
                     // P0 FIX: Support linkedProviderIds pour mise à jour
                     (resource.data.providerId != null &&
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.linkedProviderIds.hasAny([resource.data.providerId])))
                     && !request.resource.data.diff(resource.data).affectedKeys()
                          .hasAny(['isPaid', 'payment', 'paymentStatus', 'paymentId',
                                   'pricing', 'amount', 'totalAmount', 'connectionFee',
                                   'providerAmount', 'platformFee', 'refunded',
                                   'stripePaymentIntentId', 'paypalOrderId'])
                     || isAdmin());
      allow delete: if isAdmin();
    }

    // ================= CALL EXECUTION LOCKS =================
    // P0 IDEMPOTENCE: Locks pour empêcher les exécutions multiples de Cloud Tasks
    // Gérés uniquement par Cloud Functions (Admin SDK)
    match /call_execution_locks/{lockId} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Functions uniquement via Admin SDK
    }

    // ================= PAYMENTS COLLECTION =================
    // P0-7 SECURITY FIX: Les paiements ne peuvent être créés que par Cloud Functions
    // La création côté client permettrait:
    // - Création de faux paiements
    // - Manipulation des montants
    // - Bypass de la validation Stripe/PayPal
    match /payments/{paymentId} {
      allow read: if isAuthenticated() &&
                  (resource.data.userId == request.auth.uid ||
                   resource.data.clientId == request.auth.uid ||
                   resource.data.providerId == request.auth.uid ||
                   isAdmin());
      // P0-7 FIX: SEULES les Cloud Functions (Admin SDK) peuvent créer des paiements
      // Anciennement: allow create avec validation côté client (VULNÉRABLE)
      // Les paiements doivent passer par createPaymentIntent/PayPal qui valident:
      // - Rate limiting, doublons, cohérence montants, validation métier
      allow create: if false;
      // Seules les Cloud Functions peuvent mettre à jour (via Admin SDK)
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ================= REFUNDS COLLECTION =================
    match /refunds/{refundId} {
      // Client et provider peuvent voir leurs remboursements
      allow read: if isAuthenticated() &&
                  (resource.data.clientId == request.auth.uid ||
                   resource.data.providerId == request.auth.uid ||
                   resource.data.userId == request.auth.uid ||
                   isAdmin());
      // Seules les Cloud Functions peuvent écrire (via Admin SDK)
      allow write: if false;
    }

    // ================= ACCOUNTING_SEQUENCES COLLECTION =================
    // Sequences de numerotation des ecritures comptables
    match /accounting_sequences/{seqId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ================= ORDERS COLLECTION =================
    match /orders/{orderId} {
      allow read: if isAuthenticated() &&
                  (resource.data.userId == request.auth.uid ||
                   resource.data.clientId == request.auth.uid ||
                   isAdmin());
      // P1 SECURITY FIX: Validate userId/clientId matches authenticated user
      allow create: if isAuthenticated() &&
                    (request.resource.data.userId == request.auth.uid ||
                     request.resource.data.clientId == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ================= NOTIFICATIONS COLLECTION =================
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() &&
                  (resource.data.userId == request.auth.uid || isAdmin());
      // P1-6 SECURITY FIX: Valider que userId correspond à l'utilisateur authentifié
      // Empêche la création de notifications pour d'autres utilisateurs
      allow create: if (isAuthenticated() && request.resource.data.userId == request.auth.uid)
                    || isAdmin();
      // SECURITY FIX: Users can only update isRead/readAt fields, not notification content
      allow update: if (isOwner(resource.data.userId) &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'readAt']))
                    || isAdmin();
      allow delete: if isAdmin();
    }

    // ================= FCM TOKENS COLLECTION (P0 Fix: multi-device sub-collection) =================
    match /fcm_tokens/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId) || isAdmin();

      match /tokens/{tokenId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId);
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    // Legacy: keep old fcmTokens rule for backward compatibility during migration
    match /fcmTokens/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ================= IN-APP NOTIFICATIONS (P2 Security Fix) =================
    match /inapp_notifications/{notificationId} {
      allow read: if isAuthenticated() &&
                  (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if false; // Only Cloud Functions can create
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'readAt']);
      allow delete: if isAdmin();
    }

    // ================= MESSAGE EVENTS (Cloud Functions only) =================
    match /message_events/{eventId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions
    }

    // ================= MESSAGE DELIVERIES (Cloud Functions only) =================
    match /message_deliveries/{deliveryId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions
    }

    // ================= NOTIFICATION LOGS (Cloud Functions only) =================
    match /notification_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions
    }

    // ================= FAVORITES COLLECTION =================
    match /favorites/{favoriteId} {
      allow read: if isAuthenticated() &&
                  (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // ================= FAQ COLLECTION (legacy — collection vide, conservée pour rétro-compatibilité) =================
    match /faqs/{faqId} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ================= APP FAQ COLLECTION (collection officielle SOS Expat) =================
    match /app_faq/{faqId} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ================= HELP CENTER COLLECTION =================
    match /helpCenter/{articleId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ================= HELP CATEGORIES COLLECTION =================
    match /help_categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ================= HELP ARTICLES COLLECTION (for SEO sitemaps) =================
    match /help_articles/{articleId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ================= LANDING PAGES COLLECTION (for SEO sitemaps) =================
    match /landing_pages/{pageId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ================= AAA USED CONTENT COLLECTION =================
    // Tracks which bio/review content has been used for AAA profile generation
    match /aaa_used_content/{documentId} {
      allow read: if isAdmin();
      allow create: if isAdmin() &&
                   request.resource.data.keys().hasAll(['type', 'langCode', 'usedAt']) &&
                   request.resource.data.type in ['bio', 'review'];
      allow update, delete: if isAdmin();
    }

    // ================= AAA_PROFILES COLLECTION =================
    match /aaa_profiles/{profileId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ================= UI_PROFILE_CARDS COLLECTION =================
    // Cards de profil pour l'affichage UI (carrousel, grille, etc.)
    // P1-3 FIX 2026-02-23: Restrict to visible profiles only (prevent scraping hidden/inactive profiles)
    match /ui_profile_cards/{profileId} {
      allow read: if resource.data.isVisible == true || isAdmin();
      allow create, update: if isOwner(profileId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ================= UI_PROFILE_CAROUSEL COLLECTION =================
    // Données pour le carrousel de profils
    // P1-3 FIX 2026-02-23: Restrict to visible profiles only
    match /ui_profile_carousel/{profileId} {
      allow read: if resource.data.isVisible == true || isAdmin();
      allow create, update: if isOwner(profileId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ================= PROVIDER MESSAGE ORDER CUSTOMERS =================
    match /providerMessageOrderCustomers/{messageId} {
      allow create: if isAuthenticated()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.providerId is string
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 1000;

      allow read: if (isAuthenticated()
        && (request.auth.uid == resource.data.providerId
            || request.auth.uid == resource.data.senderId))
        || isAdmin();

      allow update: if isAuthenticated()
        && request.auth.uid == resource.data.providerId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);

      allow delete: if isAdmin();
    }

    // ================= SEO OPTIMIZED (AI-generated, public read) =================
    match /seo_optimized/{providerId} {
      allow read: if true;
      allow write: if false; // Only Cloud Functions write via Admin SDK
    }

    // ================= PROVIDERS TRANSLATIONS =================
    match /providers_translations/{providerId} {
      allow read: if isAuthenticated();
      allow create: if (isAuthenticated() && request.auth.uid == providerId) || isAdmin();
      allow update: if (isAuthenticated() && request.auth.uid == providerId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ================= CONFIG COLLECTION =================
    match /config/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ================= ADMIN CONFIG COLLECTION =================
    // P0 FIX: pricing and chatter_config are publicly readable (public landing pages)
    // Other admin_config documents (aaa_payout, etc.) require admin access
    match /admin_config/{docId} {
      allow read: if docId == 'pricing' || docId == 'chatter_config' || docId == 'whatsapp_groups' || isAdmin();
      allow write: if isAdmin();
    }

    // ================= SETTINGS COLLECTION =================
    // P1 SECURITY FIX: Require authentication for settings read
    // Public settings should be moved to a dedicated 'public_config' collection
    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ================= DOCUMENTS COLLECTION =================
    match /documents/{documentId} {
      allow read: if isAuthenticated() &&
                  (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ================= INVOICES COLLECTION =================
    // P0 FIX: Permet aux clients de créer leurs propres factures après paiement
    // La validation côté client assure que clientId == uid de l'utilisateur
    match /invoices/{invoiceId} {
      allow read: if isAuthenticated() &&
                  (resource.data.userId == request.auth.uid ||
                   resource.data.clientId == request.auth.uid ||
                   resource.data.providerId == request.auth.uid ||
                   isAdmin());
      // Le client peut créer une facture dont il est le client
      allow create: if isAuthenticated() &&
                    request.resource.data.clientId == request.auth.uid;
      // Seuls admins peuvent modifier/supprimer
      allow update, delete: if isAdmin();
    }

    // ================= COUPONS COLLECTION =================
    // P1-7 SECURITY FIX: Bloquer lecture directe pour empêcher énumération/brute-force
    // Les coupons sont validés via Cloud Functions (validateCoupon) qui utilise Admin SDK
    // Note: Admin peut lire pour la console admin, mais les utilisateurs normaux ne peuvent pas
    match /coupons/{couponId} {
      allow read: if isAdmin(); // Admin peut lire pour la console
      allow write: if isAdmin();
    }

    // ================= AUDIT LOGS COLLECTION =================
    // P1 SECURITY FIX: Only Cloud Functions can create audit logs (via Admin SDK)
    // This prevents users from creating fake audit entries
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if false; // Only Cloud Functions via Admin SDK
      allow update, delete: if false;
    }

    // ================= DASHBOARD RATE LIMITS COLLECTION =================
    // Rate limiting pour les tentatives de connexion au multi-dashboard
    // Géré uniquement par Cloud Functions (Admin SDK)
    match /dashboard_rate_limits/{ipAddress} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Functions uniquement via Admin SDK
    }

    // ================= DISPUTES COLLECTION (Chargebacks) =================
    // P0 FIX: Permettre les mises à jour admin pour la gestion des litiges
    match /disputes/{disputeId} {
      // Only admins can read disputes (sensitive financial data)
      allow read: if isAdmin();
      // P0 FIX: Admin peut mettre à jour (notes, timeline, status, evidence, assignee)
      // Pour les actions critiques (submit evidence to Stripe), utiliser Cloud Functions
      allow update: if (isAdmin()) &&
                    request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['notes', 'timeline', 'updatedAt', 'isAcknowledged',
                               'internalNotes', 'adminAssignee', 'adminNotes',
                               'evidenceFiles', 'evidenceSubmittedAt', 'status',
                               'resolvedAt', 'resolvedBy', 'resolution']);
      // Create: Cloud Functions only (via Stripe webhooks)
      allow create: if false;
      // Delete: jamais (audit trail)
      allow delete: if false;
    }

    // ================= ADMIN ALERTS COLLECTION =================
    match /admin_alerts/{alertId} {
      allow read: if isAdmin();
      // Admins can update (mark as read)
      allow update: if isAdmin();
      // Only Cloud Functions can create
      allow create, delete: if false;
    }

    // ================= FINANCIAL EVENTS COLLECTION =================
    match /financial_events/{eventId} {
      allow read: if isAdmin();
      // Only Cloud Functions can write
      allow write: if false;
    }

    // ================= PROVIDER BALANCE ADJUSTMENTS =================
    match /provider_balance_adjustments/{adjustmentId} {
      // Providers can read their own adjustments
      allow read: if isAuthenticated() &&
                  (resource.data.providerId == request.auth.uid || isAdmin());
      // Only Cloud Functions can write
      allow write: if false;
    }

    // ================= KYC REMINDERS LOG =================
    match /kyc_reminders_log/{logId} {
      // Only admins can read reminder logs
      allow read: if isAdmin();
      // Only Cloud Functions can write
      allow write: if false;
    }

    // ================= PAYPAL REMINDER QUEUE =================
    match /paypal_reminder_queue/{providerId} {
      // Providers can read their own reminder status
      allow read: if isAuthenticated() &&
                  (request.auth.uid == providerId || isAdmin());
      // Only Cloud Functions can write
      allow write: if false;
    }

    // ================= PAYPAL ACCOUNT LOGS =================
    match /paypal_account_logs/{logId} {
      // Providers can read their own logs, admins can read all
      allow read: if isAuthenticated() &&
                  (resource.data.providerId == request.auth.uid || isAdmin());
      // Only Cloud Functions can write
      allow write: if false;
    }

    // ================= OUTIL IA SYNC RETRY QUEUE (P0-4 FIX) =================
    match /outil_sync_retry_queue/{bookingId} {
      // Only admins can read (for monitoring)
      allow read: if isAuthenticated() && isAdmin();
      // Only Cloud Functions can write (via Admin SDK)
      allow write: if false;
    }

    // ================= PAYPAL REMINDERS LOG =================
    match /paypal_reminders_log/{logId} {
      // Only admins can read reminder logs
      allow read: if isAdmin();
      // Only Cloud Functions can write
      allow write: if false;
    }

    // ================= UNCLAIMED FUNDS =================
    match /unclaimed_funds/{fundId} {
      // Only admins can read unclaimed funds
      allow read: if isAdmin();
      // Only Cloud Functions can write
      allow write: if false;
    }

    // ================= ADMIN ACTIONS LOG =================
    match /admin_actions_log/{logId} {
      // Only admins can read action logs
      allow read: if isAdmin();
      // Only Cloud Functions can write
      allow write: if false;
    }

    // ================= PAYPAL ORDERS =================
    match /paypal_orders/{orderId} {
      // Clients can read their own orders, admins can read all
      allow read: if isAuthenticated() &&
                  (resource.data.clientId == request.auth.uid ||
                   resource.data.providerId == request.auth.uid ||
                   isAdmin());
      // Only Cloud Functions can write
      allow write: if false;
    }

    // ================= PAYPAL REFERRALS (Merchant Onboarding) =================
    match /paypal_referrals/{referralId} {
      // Providers can read their own referrals, admins can read all
      allow read: if isAuthenticated() &&
                  (resource.data.providerId == request.auth.uid ||
                   isAdmin());
      // Only Cloud Functions can write
      allow write: if false;
    }

    // ================= PAYPAL WEBHOOK EVENTS =================
    match /paypal_webhook_events/{eventId} {
      // Only admins can read webhook events
      allow read: if isAdmin();
      // Only Cloud Functions can write
      allow write: if false;
    }

    // ================= PAYOUTS COLLECTION =================
    // Versements aux prestataires (Stripe + PayPal unifiés)
    match /payouts/{payoutId} {
      // Providers can read their own payouts, admins can read all
      allow read: if isAuthenticated() &&
                  (resource.data.providerId == request.auth.uid ||
                   isAdmin());
      // Only Cloud Functions can write
      allow write: if false;
    }

    // ================= PAYPAL PAYOUTS =================
    match /paypal_payouts/{payoutId} {
      // Providers can read their own payouts, admins can read all
      allow read: if isAuthenticated() &&
                  (resource.data.providerId == request.auth.uid ||
                   isAdmin());
      // Only Cloud Functions can write
      allow write: if false;
    }

    // ================= PAYPAL PAYOUTS FAILED =================
    match /paypal_payouts_failed/{failedId} {
      // Only admins can read failed payouts
      allow read: if isAdmin();
      // Only Cloud Functions can write
      allow write: if false;
    }

    // ================= STRIPE TRANSFERS =================
    match /transfers/{transferId} {
      // Providers can read their own transfers, admins can read all
      allow read: if isAuthenticated() &&
                  (resource.data.providerId == request.auth.uid ||
                   isAdmin());
      // Only Cloud Functions can write
      allow write: if false;
    }

    // ================= PENDING TRANSFERS (Deferred KYC) =================
    match /pending_transfers/{transferId} {
      // Providers can read their own pending transfers
      // This allows them to see how much is pending until they complete KYC
      allow read: if isAuthenticated() &&
                  (resource.data.providerId == request.auth.uid ||
                   isAdmin());
      // Only Cloud Functions can write
      allow write: if false;
    }

    // ================= FAILED PAYOUTS ALERTS (PayPal KYC pending) =================
    match /failed_payouts_alerts/{alertId} {
      // Providers can read their own failed payouts
      allow read: if isAuthenticated() &&
                  (resource.data.providerId == request.auth.uid ||
                   isAdmin());
      // Only Cloud Functions can write
      allow write: if false;
    }

    // ================= AAA INTERNAL PAYOUTS =================
    // Logs for AAA profiles where money stays on platform
    match /aaa_internal_payouts/{payoutId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions
    }

    // ================= AAA EXTERNAL PAYOUTS =================
    // Logs for AAA profiles paid to consolidated external account
    match /aaa_external_payouts/{payoutId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions
    }

    // ================= KYC REMINDERS (tracking sent reminders) =================
    match /kyc_reminders/{reminderId} {
      // Only Cloud Functions and admins
      allow read: if isAdmin();
      allow write: if false;
    }

    // ================= ESCROW REPORTS (daily monitoring reports) =================
    match /escrow_reports/{reportId} {
      // Only admins can read escrow reports
      allow read: if isAdmin();
      // Only Cloud Functions can write
      allow write: if false;
    }

    // ================= FAILED TRANSFERS LOG =================
    match /failed_transfers_log/{logId} {
      // Only admins can read failed transfer logs
      allow read: if isAdmin();
      // Only Cloud Functions can write
      allow write: if false;
    }

    // ================= CALL RECORDINGS =================
    match /call_recordings/{recordingId} {
      // Only admins can access recordings
      allow read: if isAdmin();
      // Only Cloud Functions can write
      allow write: if false;
    }

    // ================= TECHNICAL ALERTS =================
    match /technical_alerts/{alertId} {
      // Only admins/devs can access
      allow read: if isAdmin();
      allow update: if isAdmin(); // To mark as resolved
      allow create, delete: if false; // Only Cloud Functions
    }

    // ================= ADMIN NOTIFICATIONS =================
    match /admin_notifications/{notificationId} {
      // Only admins can access
      allow read: if isAdmin();
      allow update: if isAdmin(); // To mark as processed
      allow create, delete: if false; // Only Cloud Functions
    }

    // ================= COST MONITORING =================
    match /cost_metrics/{docId} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Functions only
    }

    match /cost_alerts/{alertId} {
      allow read: if isAdmin();
      allow update: if isAdmin(); // Pour marquer comme lu
      allow create, delete: if false; // Cloud Functions only
    }

    // ================= PROVIDER NOTIFICATIONS COLLECTION =================
    // P0 FIX: Collection pour les notifications des prestataires (pendingRequests, unreadMessages)
    // Utilisée par AiAssistantPageV2.tsx pour afficher les compteurs
    match /provider_notifications/{providerId} {
      // Le provider lui-même peut lire ses notifications
      // Les utilisateurs avec linkedProviderIds peuvent aussi lire (multi-provider)
      allow read: if isAuthenticated() && (
        request.auth.uid == providerId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.linkedProviderIds.hasAny([providerId]) ||
        isAdmin()
      );
      // Seules les Cloud Functions peuvent écrire (via Admin SDK)
      allow write: if false;
    }

    // ================= SUBSCRIPTIONS COLLECTION =================
    match /subscriptions/{providerId} {
      // Le provider peut lire son propre abonnement
      allow read: if isOwner(providerId) || isAdmin();
      // Seules les Cloud Functions peuvent écrire (via Admin SDK)
      allow write: if false;
    }

    // ================= SUBSCRIPTION PLANS COLLECTION =================
    match /subscription_plans/{planId} {
      // Lecture publique (pour afficher les prix)
      allow read: if true;
      // Seuls les admins peuvent modifier les plans
      allow write: if isAdmin();
    }

    // ================= AI USAGE COLLECTION =================
    match /ai_usage/{userId} {
      // L'utilisateur peut lire son propre usage (providers et clients)
      // Note: Les clients n'auront pas de document, mais peuvent vérifier
      allow read: if isOwner(userId) || isAdmin();
      // Seules les Cloud Functions peuvent écrire
      allow write: if false;
    }

    // ================= SUBSCRIPTION LOGS COLLECTION =================
    match /subscription_logs/{logId} {
      // Seuls les admins peuvent lire les logs d'abonnement
      allow read: if isAdmin();
      // Seules les Cloud Functions peuvent écrire
      allow write: if false;
    }

    // ================= SUBSCRIPTION EVENTS COLLECTION =================
    // P0 FIX: Événements d'abonnement pour l'onglet IA Analytics
    // (upgrades, downgrades, cancellations, renewals, trials, etc.)
    match /subscription_events/{eventId} {
      // Lecture: Admin uniquement (données sensibles)
      allow read: if isAdmin();
      // Admin peut mettre à jour (acknowledge, notes)
      allow update: if (isAdmin()) &&
                    request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['isAcknowledged', 'acknowledgedAt', 'acknowledgedBy',
                               'notes', 'internalNotes', 'updatedAt']);
      // Création: Cloud Functions uniquement (via triggers Stripe)
      allow create, delete: if false;
    }

    // ================= PROCESSED STRIPE EVENTS (Idempotency) =================
    match /processed_stripe_events/{eventId} {
      // Seuls les admins peuvent lire
      allow read: if isAdmin();
      // Seules les Cloud Functions peuvent écrire
      allow write: if false;
    }

    // ================= QUOTA RESET LOGS =================
    match /quota_reset_logs/{logId} {
      // Seuls les admins peuvent lire
      allow read: if isAdmin();
      // Seules les Cloud Functions peuvent écrire
      allow write: if false;
    }

    // ================= TRIAL EXPIRATION LOGS =================
    match /trial_expiration_logs/{logId} {
      // Seuls les admins peuvent lire
      allow read: if isAdmin();
      // Seules les Cloud Functions peuvent écrire
      allow write: if false;
    }

    // ================= PROCESSED WEBHOOK EVENTS (Idempotency) =================
    match /processed_webhook_events/{eventId} {
      // Seuls les admins peuvent lire
      allow read: if isAdmin();
      // Seules les Cloud Functions peuvent écrire
      allow write: if false;
    }

    // ================= RATE LIMITS (Anti-abuse) =================
    match /rate_limits/{limitId} {
      // Seuls les admins peuvent lire
      allow read: if isAdmin();
      // Seules les Cloud Functions peuvent écrire
      allow write: if false;
    }

    // ================= ADMIN AUDIT LOGS (Compliance) =================
    match /admin_audit_logs/{logId} {
      // Seuls les admins peuvent lire les logs d'audit
      allow read: if isAdmin();
      // Seules les Cloud Functions peuvent écrire (immuable)
      allow write: if false;
    }

    // ================= RESTORE OPERATIONS (Backup Restore Tracking) =================
    match /restore_operations/{operationId} {
      // Seuls les admins peuvent lire les opérations de restauration
      allow read: if isAdmin();
      // Seules les Cloud Functions peuvent écrire
      allow write: if false;
    }

    // ================= INVOICE RECORDS (Prestations) =================
    match /invoice_records/{invoiceId} {
      // Les utilisateurs peuvent lire leurs propres factures (client ou provider)
      allow read: if isAuthenticated() &&
                  (resource.data.clientId == request.auth.uid ||
                   resource.data.providerId == request.auth.uid ||
                   isAdmin());
      // Le client peut créer une facture dont il est le client
      // (sécurisé: on vérifie que clientId == uid de l'utilisateur)
      allow create: if isAuthenticated() &&
                    request.resource.data.clientId == request.auth.uid;
      // Seuls admins peuvent modifier/supprimer
      allow update, delete: if isAdmin();
    }

    // ================= ADMIN INVOICES (Console admin) =================
    // P1 SECURITY FIX: Only Cloud Functions can create admin invoices
    match /admin_invoices/{invoiceId} {
      // Seuls les admins peuvent accéder
      allow read: if isAdmin();
      // P1 FIX: Only Cloud Functions via Admin SDK can create
      allow create: if false;
      allow update, delete: if isAdmin();
    }

    // ================= AUDIT LOGS (Facturation) =================
    // P1 SECURITY FIX: Only Cloud Functions can create audit logs
    match /audit_logs/{logId} {
      // Seuls les admins peuvent lire les logs
      allow read: if isAdmin();
      // P1 FIX: Only Cloud Functions via Admin SDK can create (prevents log forgery)
      allow create: if false;
      allow update, delete: if isAdmin();
    }

    // ================= LEGAL DOCUMENTS COLLECTION =================
    // Documents légaux (CGU, CGV, Politique de confidentialité, etc.)
    match /legal_documents/{docId} {
      // Lecture publique pour les pages légales
      allow read: if true;
      // Seuls les admins peuvent modifier
      allow write: if isAdmin();
    }

    // ================= ADMIN SETTINGS COLLECTION =================
    // Paramètres d'administration
    match /admin_settings/{docId} {
      // Seuls les admins peuvent lire et écrire
      allow read, write: if isAdmin();
    }

    // ================= AUTH CLAIMS LOGS COLLECTION =================
    // Logs des changements de claims auth
    match /auth_claims_logs/{logId} {
      // Seuls les admins peuvent lire
      allow read: if isAdmin();
      // Seules les Cloud Functions peuvent écrire
      allow write: if false;
    }

    // ================= COUNTRY SETTINGS COLLECTION =================
    // Paramètres des pays activés/désactivés
    match /country_settings/{countryId} {
      // Lecture publique pour charger les pays activés sur le frontend
      allow read: if true;
      // Seuls les admins peuvent modifier
      allow write: if isAdmin();
    }

    // ================= BOOKING REQUESTS COLLECTION =================
    match /booking_requests/{bookingId} {
      // Lecture : client ou provider concerné, agency_manager pour ses providers liés, ou admin/dev
      // OPTIMISATION 2026-02-12: Utilisation de la fonction helper hasAgencyAccessToProvider
      allow read: if isAuthenticated() &&
                  (resource.data.clientId == request.auth.uid ||
                   resource.data.providerId == request.auth.uid ||
                   isAdmin() ||
                   hasAgencyAccessToProvider(resource.data.providerId));

      // Création : client authentifié avec validation des champs requis
      allow create: if isAuthenticated() &&
                    request.resource.data.clientId == request.auth.uid &&
                    request.resource.data.providerId is string &&
                    request.resource.data.serviceType is string &&
                    request.resource.data.status == "pending";

      // Mise à jour : client ou provider concerné (pour changer le statut, etc.)
      allow update: if isAuthenticated() &&
                    (resource.data.clientId == request.auth.uid ||
                     resource.data.providerId == request.auth.uid ||
                     isAdmin());

      // Suppression : admin, dev, ou agency_manager pour ses providers liés
      // OPTIMISATION 2026-02-12: Utilisation de la fonction helper hasAgencyAccessToProvider
      allow delete: if isAuthenticated() &&
                    (isAdmin() ||
                     hasAgencyAccessToProvider(resource.data.providerId));
    }

    // ================= AUTH LOGS COLLECTION =================
    match /auth_logs/{logId} {
      // Seuls les admins peuvent lire
      allow read: if isAdmin();
      // Utilisateurs authentifiés peuvent créer leurs propres logs
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      // Cloud Functions seules peuvent modifier/supprimer
      allow update, delete: if false;
    }

    // ================= LOGS COLLECTION (Auth Events) =================
    // Collection utilisée par logAuthEvent() dans AuthContext
    match /logs/{logId} {
      // Seuls les admins peuvent lire les logs
      allow read: if isAdmin();
      // Utilisateurs authentifiés peuvent créer des logs
      allow create: if isAuthenticated();
      // Cloud Functions seules peuvent modifier/supprimer
      allow update, delete: if false;
    }

    // ================= ERROR LOGS COLLECTION =================
    match /error_logs/{logId} {
      // Seuls les admins peuvent lire
      allow read: if isAdmin();
      // Utilisateurs authentifiés peuvent logger les erreurs
      allow create: if isAuthenticated();
      // Cloud Functions seules peuvent modifier/supprimer
      allow update, delete: if false;
    }

    // ================= PERFORMANCE METRICS COLLECTION =================
    // P0 FIX: Permet aux utilisateurs authentifiés de logger les métriques de performance
    // (ex: temps de génération des factures, latence des appels, etc.)
    match /performance_metrics/{metricId} {
      // Seuls les admins peuvent lire les métriques
      allow read: if isAdmin();
      // Utilisateurs authentifiés peuvent créer des métriques
      allow create: if isAuthenticated();
      // Cloud Functions seules peuvent modifier/supprimer
      allow update, delete: if false;
    }

    // ================= INVOICE LOCKS COLLECTION =================
    // P0-3 FIX: Distributed lock pour empêcher la génération de factures en double
    // Géré via Cloud Functions (acquireInvoiceLock, releaseInvoiceLock)
    match /invoice_locks/{lockId} {
      // Lecture pour vérifier si un lock existe
      allow read: if isAuthenticated();
      // Création/modification/suppression via Cloud Functions uniquement
      allow create, update, delete: if false;
    }

    // ================= NOTIFICATION DLQ COLLECTION =================
    // P1-6 FIX: Dead Letter Queue pour les notifications échouées
    match /notification_dlq/{docId} {
      // Seuls les admins peuvent lire
      allow read: if isAdmin();
      // Cloud Functions seules peuvent créer/modifier
      allow create, update, delete: if false;
    }

    // ================= SCHEDULING ERRORS COLLECTION =================
    // Logs des erreurs de planification d'appels
    match /scheduling_errors/{errorId} {
      allow read: if isAdmin();
      allow create: if false; // Cloud Functions only
      allow update, delete: if false;
    }

    // ================= ANALYTICS EVENTS COLLECTION =================
    match /analytics_events/{eventId} {
      // Seuls les admins peuvent lire
      allow read: if isAdmin();
      // Utilisateurs authentifiés peuvent créer des événements
      allow create: if isAuthenticated();
      // Cloud Functions seules peuvent modifier/supprimer
      allow update, delete: if false;
    }

    // ================= ANALYTICS LANGUAGE MISMATCHES =================
    match /analytics_language_mismatches/{eventId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ================= ANALYTICS USER ACTIONS =================
    match /analytics_user_actions/{eventId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ================= ANALYTICS CONVERSIONS =================
    match /analytics_conversions/{eventId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ================= ANALYTICS ERRORS =================
    match /analytics_errors/{eventId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ================= ANALYTICS PERFORMANCE =================
    match /analytics_performance/{eventId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ================= ANALYTICS COUNTERS =================
    // P0 SECURITY FIX: Seules les Cloud Functions peuvent manipuler les compteurs
    // Empêche la manipulation des métriques par des utilisateurs malveillants
    match /analytics_counters/{counterId} {
      allow read: if isAdmin();
      // Seules les Cloud Functions via Admin SDK peuvent écrire
      allow write: if false;
    }

    // ================= AD CONVERSIONS (Attribution Publicitaire) =================
    // Collection pour tracker les conversions avec attribution de source de trafic
    // (Facebook Ads, Google Ads, TikTok, etc.)
    match /ad_conversions/{conversionId} {
      // Seuls les admins peuvent lire les données d'attribution
      allow read: if isAdmin();
      // SECURITY FIX: Require authentication + validate required fields to prevent denial-of-wallet abuse
      allow create: if request.auth != null &&
                    request.resource.data.keys().hasAll(['source', 'timestamp']) &&
                    request.resource.data.source is string &&
                    request.resource.data.source.size() > 0 &&
                    request.resource.data.source.size() < 100 &&
                    request.resource.data.timestamp is timestamp &&
                    request.resource.data.keys().size() < 20;
      // Les conversions ne peuvent jamais être modifiées ou supprimées (audit trail)
      allow update, delete: if false;
    }

    // ================= FAQ TRANSLATIONS CACHE =================
    match /faq_translations_cache/{cacheId} {
      // Lecture publique pour les FAQ traduites
      allow read: if true;
      // Seuls les admins peuvent écrire
      allow write: if isAdmin();
    }

    // ================= CONTACT MESSAGES COLLECTION =================
    // Messages de contact depuis le formulaire footer et page contact
    // P0 SECURITY: Création via Cloud Function avec reCAPTCHA pour éviter le spam
    match /contact_messages/{messageId} {
      // Seuls les admins peuvent lire les messages de contact
      allow read: if isAdmin();
      // P0 SECURITY: Création désactivée directement depuis le client
      // Utiliser la Cloud Function createContactMessage avec reCAPTCHA
      // Cette protection évite le spam et les attaques "denial of wallet"
      allow create: if false;
      // Seuls les admins peuvent mettre à jour (marquer comme lu, répondre)
      allow update: if isAdmin();
      // Seuls les admins peuvent supprimer
      allow delete: if isAdmin();
    }

    // ================= USER REPORTS COLLECTION =================
    // Signalements utilisateurs (avis inappropriés, profils suspects, etc.)
    match /reports/{reportId} {
      // L'utilisateur peut lire ses propres signalements, admins peuvent tout lire
      allow read: if isAuthenticated() &&
                  (resource.data.reporterId == request.auth.uid || isAdmin());

      // Utilisateurs authentifiés peuvent créer un signalement
      // - Doit être le reporter (pas d'usurpation)
      // - Ne peut pas se signaler soi-même
      // - Doit avoir une raison valide
      allow create: if isAuthenticated() &&
                    request.resource.data.reporterId == request.auth.uid &&
                    request.resource.data.targetId != request.auth.uid &&
                    request.resource.data.reason is string &&
                    request.resource.data.reason.size() >= 5;

      // Seuls les admins peuvent mettre à jour (résoudre, rejeter)
      allow update: if isAdmin();

      // Seuls les admins peuvent supprimer
      allow delete: if isAdmin();
    }

    // ================= EMAIL LOGS COLLECTION =================
    // Logs des emails envoyés (pour traçabilité)
    match /email_logs/{logId} {
      // Seuls les admins peuvent lire les logs
      allow read: if isAdmin();
      // Seules les Cloud Functions peuvent écrire
      allow write: if false;
    }

    // ================= SECURITY ALERTS COLLECTION =================
    // Alertes de sécurité (brute force, fraude, etc.)
    // NOTE: Aucun pays n'est blacklisté - détection basée sur comportements anormaux
    match /security_alerts/{alertId} {
      // Seuls les admins peuvent lire les alertes de sécurité
      allow read: if isAdmin();
      // Admins peuvent mettre à jour (acknowledge, resolve)
      allow update: if isAdmin();
      // Seules les Cloud Functions peuvent créer/supprimer
      allow create, delete: if false;
    }

    // ================= ALERT RATE LIMITS =================
    // Rate limiting pour éviter le spam d'alertes
    match /alert_rate_limits/{limitId} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Functions only
    }

    // ================= ADMIN ALERT PREFERENCES =================
    // Préférences de notification des admins
    match /admin_alert_preferences/{adminId} {
      // Admin peut lire/modifier ses propres préférences
      allow read: if isOwner(adminId) || isAdmin();
      allow write: if isOwner(adminId) || isAdmin();
    }

    // ================= THREAT SCORES =================
    // Scores de menace par utilisateur/IP
    match /threat_scores/{entityId} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Functions only
    }

    // ================= BLOCKED ENTITIES =================
    // Entités bloquées (utilisateurs, IPs)
    match /blocked_entities/{entityId} {
      allow read: if isAdmin();
      // Admins peuvent débloquer manuellement
      allow update, delete: if isAdmin();
      allow create: if false; // Cloud Functions only
    }

    // ================= GEO PROFILES =================
    // Profils géographiques des utilisateurs (pour détection anomalies)
    match /geo_profiles/{userId} {
      // L'utilisateur peut voir son propre profil, admins tout
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false; // Cloud Functions only
    }

    // ================= FRAUD PATTERNS =================
    // Patterns de fraude détectés
    match /fraud_patterns/{patternId} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Functions only
    }

    // ================= API ABUSE LOGS =================
    // Logs d'abus API (scraping, injection, etc.)
    match /api_abuse_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Functions only
    }

    // ================= SECURITY EVENTS (raw events) =================
    // Événements de sécurité bruts avant traitement
    match /security_events/{eventId} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Functions only
    }

    // ================= LOGIN ATTEMPTS =================
    // Tentatives de login (pour détection brute force)
    match /login_attempts/{attemptId} {
      allow read: if isAdmin();
      // Les Cloud Functions créent les entrées lors des tentatives de connexion
      allow write: if false;
    }

    // ================= ADMIN SECURITY ACTIONS =================
    // Actions de sécurité prises par les admins (audit trail)
    match /admin_security_actions/{actionId} {
      allow read: if isAdmin();
      // Admins peuvent créer des actions (avec leur uid)
      allow create: if isAdmin() && request.resource.data.adminId == request.auth.uid;
      allow update, delete: if false; // Immutable audit trail
    }

    // ================= SECURITY ROUTING CONFIG =================
    // Configuration du routing des alertes de sécurité
    match /security_routing/{configId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // =====================================================================
    // SECTION COMPTABILITE / FINANCE - NOUVELLES COLLECTIONS
    // Roles: SUPER_ADMIN, FINANCE_ADMIN, VIEWER
    // =====================================================================

    // ================= HELPER FUNCTIONS FINANCE =================
    // Note: Ces fonctions sont deja definies en haut du fichier
    // Elles acceptent les roles: admin, FINANCE_ADMIN, SUPER_ADMIN

    // ================= COUNTRY TAX CONFIGS =================
    // Configuration fiscale par pays (taux TVA, seuils, etc.)
    match /country_tax_configs/{countryCode} {
      // Lecture: tout utilisateur authentifie (pour afficher les prix TTC)
      allow read: if isAuthenticated();
      // Ecriture: FINANCE_ADMIN ou SUPER_ADMIN uniquement
      allow create, update: if isFinanceAdmin();
      allow delete: if isSuperAdmin();
    }

    // ================= EXCHANGE RATES (ECB) =================
    // Taux de change BCE quotidiens - conformite comptable estonienne
    match /exchange_rates/{date} {
      // Lecture: admin ou expert-comptable
      allow read: if isFinanceReader();
      // Ecriture: Cloud Functions uniquement (fetch ECB automatique)
      allow write: if false;
    }

    // ================= ACCOUNTING ARCHIVES =================
    // Archives comptables (fallback Firestore si Storage indisponible)
    match /accounting_archives/{period} {
      allow read: if isFinanceReader();
      allow write: if false;
    }

    // ================= ACCOUNTING CLOSING REPORTS =================
    match /accounting_closing_reports/{period} {
      allow read: if isFinanceReader();
      allow write: if false;
    }

    // ================= TAX CONFIGS =================
    // Configuration TVA par pays (taux standard, reduit, etc.)
    match /tax_configs/{countryCode} {
      // Lecture: admin ou expert-comptable
      allow read: if isFinanceReader();
      // Ecriture: admin uniquement
      allow write: if isAdmin();
    }

    // ================= COUNTRIES =================
    // Liste des pays (pour les selecteurs)
    match /countries/{countryId} {
      // Lecture: tout utilisateur authentifie
      allow read: if isAuthenticated();
      // Ecriture: admin uniquement
      allow write: if isAdmin();
    }

    // ================= TAX DECLARATIONS =================
    // Declarations TVA par pays/periode
    match /tax_declarations/{declarationId} {
      // Lecture: admin ou expert-comptable
      allow read: if isFinanceReader();
      // Ecriture: admin uniquement
      allow write: if isAdmin();
    }

    // ================= THRESHOLD TRACKING =================
    // Suivi des seuils de CA par pays (pour obligations fiscales)
    match /threshold_tracking/{trackingId} {
      // Lecture: admin ou expert-comptable
      allow read: if isFinanceReader();
      // Ecriture: admin ou Cloud Functions
      allow write: if isAdmin();
    }

    // ================= THRESHOLD ALERTS =================
    // Alertes quand un seuil est proche ou atteint
    match /threshold_alerts/{alertId} {
      // Lecture: admin ou expert-comptable
      allow read: if isFinanceReader();
      // Ecriture: admin
      allow write: if isAdmin();
    }

    // ================= JOURNAL ENTRIES =================
    // Ecritures comptables (debit/credit)
    // IMMUTABILITE: une ecriture POSTED ne peut plus etre modifiee
    match /journal_entries/{entryId} {
      // Lecture: FINANCE_ADMIN, SUPER_ADMIN ou EXPERT-COMPTABLE
      allow read: if isFinanceReader();
      // Creation: Cloud Functions uniquement (genere automatiquement)
      allow create: if false;
      // Update: FINANCE_ADMIN peut faire passer DRAFT -> POSTED uniquement
      // Une fois POSTED, plus aucune modification possible
      allow update: if isFinanceAdmin() &&
                    resource.data.status == 'DRAFT' &&
                    request.resource.data.status in ['DRAFT', 'POSTED'] &&
                    // Seuls ces champs peuvent etre modifies en DRAFT
                    request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['status', 'postedAt', 'postedBy', 'notes', 'description']);
      // Delete: JAMAIS (immutabilite comptable)
      allow delete: if false;
    }

    // ================= SUPPORTING DOCUMENTS =================
    // Pieces justificatives externes (factures fournisseurs, recus, releves, contrats)
    // Retention legale estonienne 7 ans - JAMAIS de suppression
    match /supporting_documents/{docId} {
      // Lecture: admin ou expert-comptable
      allow read: if isFinanceReader();
      // Creation: Cloud Functions uniquement (numerotation sequentielle)
      allow create: if false;
      // Modification: admin uniquement, champs immutables proteges
      allow update: if isFinanceAdmin() &&
                    !request.resource.data.diff(resource.data).affectedKeys()
                      .hasAny(['documentNumber', 'uploadedBy', 'createdAt']);
      // Suppression: JAMAIS (retention legale 7 ans)
      allow delete: if false;
    }

    // Compteurs numerotation sequentielle - Cloud Functions only
    match /supporting_document_counters/{year} {
      allow read: if isFinanceReader();
      allow write: if false;
    }

    // ================= CHART OF ACCOUNTS =================
    // Plan comptable (liste des comptes: 411000 Clients, 701000 Ventes, etc.)
    match /chart_of_accounts/{accountCode} {
      // Lecture: FINANCE_ADMIN, SUPER_ADMIN ou EXPERT-COMPTABLE
      allow read: if isFinanceReader();
      // Ecriture: SUPER_ADMIN uniquement (modification du plan comptable = risque)
      allow create, update, delete: if isSuperAdmin();
    }

    // ================= ACCOUNTING PERIODS =================
    // Periodes comptables (mois, trimestres, annees)
    match /accounting_periods/{periodId} {
      // Lecture: FINANCE_ADMIN, SUPER_ADMIN ou EXPERT-COMPTABLE
      allow read: if isFinanceReader();
      // Creation/Suppression: SUPER_ADMIN uniquement
      allow create, delete: if isSuperAdmin();
      // Update: FINANCE_ADMIN peut cloturer une periode (status: OPEN -> CLOSED)
      // SUPER_ADMIN peut tout modifier
      allow update: if isSuperAdmin() ||
                    (isFinanceAdmin() &&
                     resource.data.status == 'OPEN' &&
                     request.resource.data.status == 'CLOSED' &&
                     request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['status', 'closedAt', 'closedBy']));
    }

    // ================= TAX FILINGS =================
    // Declarations fiscales (TVA mensuelle, trimestrielle, annuelle)
    match /tax_filings/{filingId} {
      // Lecture: FINANCE_ADMIN, SUPER_ADMIN ou EXPERT-COMPTABLE
      allow read: if isFinanceReader();
      // Creation: Cloud Functions uniquement (genere automatiquement)
      allow create: if false;
      // Update: FINANCE_ADMIN peut changer le statut et ajouter des notes
      allow update: if isFinanceAdmin() &&
                    request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['status', 'filedAt', 'filedBy', 'referenceNumber',
                               'notes', 'attachments', 'submittedAt', 'submittedBy']);
      // Delete: JAMAIS (obligation legale de conservation)
      allow delete: if false;
    }

    // ================= VAT VALIDATIONS =================
    // Cache des validations de numeros de TVA intracommunautaire (VIES)
    match /vat_validations/{validationId} {
      // Lecture: tout utilisateur authentifie (pour checkout B2B)
      allow read: if isAuthenticated();
      // Ecriture: Cloud Functions uniquement (via API VIES)
      allow write: if false;
    }

    // ================= COUNTRY PRICING =================
    // Prix par pays (conversion devises, ajustements locaux)
    match /country_pricing/{countryCode} {
      // Lecture: tout utilisateur authentifie (pour afficher les prix)
      allow read: if isAuthenticated();
      // Ecriture: SUPER_ADMIN uniquement (impact business majeur)
      allow write: if isSuperAdmin();
    }

    // ================= RECONCILIATION RECORDS =================
    // Rapprochements bancaires et comptables
    match /reconciliation_records/{recordId} {
      // Lecture: FINANCE_ADMIN, SUPER_ADMIN ou EXPERT-COMPTABLE
      allow read: if isFinanceReader();
      // Ecriture: FINANCE_ADMIN ou SUPER_ADMIN
      allow create, update: if isFinanceAdmin();
      // Delete: SUPER_ADMIN uniquement (pour correction d'erreurs)
      allow delete: if isSuperAdmin();
    }

    // ================= FINANCE AUDIT LOGS =================
    // Logs d'audit specifiques aux operations comptables
    // Toute modification comptable doit etre tracee ici
    match /finance_audit_logs/{logId} {
      // Lecture: FINANCE_ADMIN, SUPER_ADMIN ou EXPERT-COMPTABLE
      allow read: if isFinanceReader();
      // Ecriture: Cloud Functions uniquement (audit automatique)
      allow write: if false;
    }

    // ================= TAX FILING NOTIFICATIONS =================
    // Rappels automatiques pour echeances fiscales
    match /tax_filing_notifications/{notifId} {
      // Lecture: Admin ou expert-comptable
      allow read: if isFinanceReader();
      // Ecriture: Cloud Functions uniquement
      allow write: if false;
    }

    // ================= TAX FILING CONFIGS =================
    // Configuration par type de declaration (seuils, emails de notification)
    match /tax_filing_configs/{configId} {
      // Lecture: Admin ou expert-comptable
      allow read: if isFinanceReader();
      // Ecriture: Admin uniquement (configuration manuelle)
      allow write: if isAdmin();
    }

    // ================= COUNTRY FISCAL CONFIGS =================
    // Configuration fiscale complete pour 197 pays
    // (VAT/GST/Sales Tax, seuils, regimes digital services, etc.)
    match /country_fiscal_configs/{countryCode} {
      // Lecture publique (pour afficher prix TTC, info paiement)
      allow read: if true;
      // Ecriture: Admin uniquement (Cloud Functions pour seed)
      allow write: if isAdmin();
    }

    // ================= COUNTRY SUBDIVISIONS =================
    // NOTE: Collection not currently used in code - kept for future use
    // (seeds/initCountryConfigs commented out in index.ts, CountryConfigService not imported anywhere)
    // USA states (51) + Canada provinces (13)
    // Taxes specifiques par etat/province (Sales Tax, GST/HST/PST/QST)
    match /country_subdivisions/{subdivisionId} {
      // Lecture publique (pour calculs de taxe)
      allow read: if true;
      // Ecriture: Admin uniquement
      allow write: if isAdmin();
    }

    // ================= SYSTEM ALERTS =================
    // Alertes systeme critiques (DLQ, backups, disputes, erreurs)
    // Cloud Functions creent les alertes, admin les lit et acquitte
    match /system_alerts/{alertId} {
      // Lecture: Admin uniquement
      allow read: if isAdmin();
      // Creation: Cloud Functions uniquement (via Admin SDK)
      allow create: if false;
      // Mise a jour: Admin peut acquitter les alertes
      allow update: if isAdmin();
      // Suppression: Admin uniquement (cleanup)
      allow delete: if isAdmin();
    }

    // ================= WEBHOOK DLQ (Dead Letter Queue) =================
    // Evenements webhook en echec pour retry manuel
    match /webhook_dlq/{eventId} {
      // Lecture: Admin uniquement
      allow read: if isAdmin();
      // Ecriture: Cloud Functions uniquement
      allow write: if false;
    }

    // ================= SYSTEM LOGS =================
    // Logs systeme (backups, migrations, etc.)
    match /system_logs/{logId} {
      // Lecture: Admin uniquement
      allow read: if isAdmin();
      // Ecriture: Cloud Functions uniquement
      allow write: if false;
    }

    // ================= PROVIDER STATUS LOGS =================
    // Logs de changement de statut des prestataires (busy/available)
    // Utilisé pour le feature shareBusyStatus (multi-providers)
    match /provider_status_logs/{logId} {
      // Lecture: Admin uniquement
      allow read: if isAdmin();
      // Ecriture: Cloud Functions uniquement
      allow write: if false;
    }

    // ================= FIRESTORE BACKUPS =================
    // Metadonnees des sauvegardes Firestore (morningBackup, manual, etc.)
    match /backups/{backupId} {
      // Lecture: Admin uniquement
      allow read: if isAdmin();
      // Ecriture: Cloud Functions uniquement (Admin SDK)
      allow write: if false;
    }

    // ================= AUTH BACKUPS =================
    // Metadonnees des backups Firebase Auth
    match /auth_backups/{backupId} {
      // Lecture: Admin uniquement
      allow read: if isAdmin();
      // Ecriture: Cloud Functions uniquement
      allow write: if false;
    }

    // ================= LOCAL BACKUPS =================
    // Registre des sauvegardes locales (PC)
    match /local_backups/{backupId} {
      // Lecture: Admin uniquement
      allow read: if isAdmin();
      // Ecriture: Cloud Functions uniquement (registerLocalBackup)
      allow write: if false;
    }

    // ================= MAIL (Firebase Email Extension) =================
    // Collection pour envoi d'emails via extension
    match /mail/{mailId} {
      // Lecture: Admin uniquement (debug)
      allow read: if isAdmin();
      // Ecriture: Cloud Functions uniquement
      allow write: if false;
    }

    // ================= DR TEST REPORTS =================
    // Rapports de tests Disaster Recovery
    match /dr_test_reports/{reportId} {
      // Lecture: Admin uniquement
      allow read: if isAdmin();
      // Ecriture: Cloud Functions uniquement
      allow write: if false;
    }

    // ================= SYSTEM CONFIG =================
    // Configuration systeme (seuils d'alertes, etc.)
    match /system_config/{configId} {
      // Lecture: Admin uniquement
      allow read: if isAdmin();
      // Ecriture: Admin uniquement
      allow write: if isAdmin();
    }

    // ================= VALIDATION QUEUE =================
    // File d'attente de validation des profils prestataires
    // Audit trail: suppression interdite pour tracabilite complete
    match /validation_queue/{validationId} {
      // Lecture: Admin uniquement
      allow read: if isAdmin();
      // Creation: Cloud Functions uniquement (via Admin SDK)
      allow create: if false;
      // Mise a jour: Admin uniquement (pour valider/rejeter)
      allow update: if isAdmin();
      // Suppression: JAMAIS (audit trail obligatoire)
      allow delete: if false;

      // Sous-collection: historique des validations
      match /validation_history/{historyId} {
        // Lecture: Admin uniquement
        allow read: if isAdmin();
        // Ecriture: Cloud Functions uniquement (via Admin SDK)
        allow write: if false;
      }
    }

    // ================= PROVIDER ACTION LOGS =================
    // Logs des actions des prestataires (connexion, deconnexion, modifications profil)
    // Immutable: ecriture Cloud Functions uniquement
    match /provider_action_logs/{logId} {
      // Lecture: Admin uniquement
      allow read: if isAdmin();
      // Ecriture: Cloud Functions uniquement (via Admin SDK)
      allow write: if false;
    }

    // ================= CONNECTION LOGS =================
    // Logs de connexion/deconnexion des utilisateurs
    // Immutable apres creation: pas de modification ni suppression
    match /connection_logs/{logId} {
      // Lecture: Admin uniquement
      allow read: if isAdmin();
      // Creation: Cloud Functions uniquement (via Admin SDK)
      // Note: Les Cloud Functions valident les champs requis (userId, timestamp, eventType, etc.)
      allow create: if false;
      // Mise a jour: JAMAIS (immutable)
      allow update: if false;
      // Suppression: JAMAIS (audit trail)
      allow delete: if false;
    }

    // ================= SERVICE BALANCE ALERTS =================
    // Alertes sur les soldes de services (credits faibles, etc.)
    match /service_balance_alerts/{alertId} {
      // Lecture: Admin uniquement
      allow read: if isAdmin();
      // Ecriture: Admin uniquement (pour acquitter les alertes)
      allow write: if isAdmin();
    }

    // ================= SERVICE BALANCE THRESHOLDS =================
    // Configuration des seuils d'alerte pour les soldes de services
    match /service_balance_thresholds/{thresholdId} {
      // Lecture: Admin uniquement
      allow read: if isAdmin();
      // Ecriture: Admin uniquement
      allow write: if isAdmin();
    }

    // ================= ANALYTICS DAILY =================
    // Metriques analytiques agregees par jour
    // Immutable: genere automatiquement par Cloud Functions
    match /analytics_daily/{dateId} {
      // Lecture: Admin uniquement
      allow read: if isAdmin();
      // Ecriture: Cloud Functions uniquement (via Admin SDK)
      allow write: if false;
    }

    // ================= AI CALL LOGS =================
    // Logs des appels IA (GPT, Claude, Perplexity, etc.)
    // Usage: Console admin pour monitoring des couts et performances IA
    match /ai_call_logs/{logId} {
      // Lecture: Admin uniquement (donnees sensibles - couts, tokens)
      allow read: if isAdmin();
      // Ecriture: Cloud Functions uniquement (via Admin SDK)
      allow write: if false;
    }

    // ================= OPENAI USAGE METRICS =================
    // Metriques d'utilisation OpenAI (tokens, couts par modele)
    // Usage: Console admin - onglet IA Analytics
    match /openai_usage_metrics/{metricId} {
      // Lecture: Admin uniquement
      allow read: if isAdmin();
      // Ecriture: Cloud Functions uniquement (via Admin SDK)
      allow write: if false;
    }

    // ================= SERVICE ALERTS =================
    // Alertes des services externes (Twilio, Stripe, OpenAI, etc.)
    // Usage: Console admin - widget alertes services
    match /service_alerts/{alertId} {
      // Lecture: Admin uniquement
      allow read: if isAdmin();
      // Mise a jour: Admin peut acquitter les alertes
      allow update: if isAdmin();
      // Creation/Suppression: Cloud Functions uniquement
      allow create, delete: if false;
    }

    // ================= USER FEEDBACK =================
    // Feedbacks utilisateurs (bugs, suggestions, problèmes UX)
    // Usage: Formulaire de signalement accessible à tous
    match /user_feedback/{feedbackId} {
      // Lecture: Admin uniquement (console admin)
      allow read: if isAdmin();
      // Création: Tous (même non authentifiés) avec validation
      // - email requis et format valide
      // - type requis (bug, ux_friction, suggestion, other)
      // - description requise (min 10 caractères)
      // NOTE: .size() compte les BYTES UTF-8, pas les caractères!
      // Les caractères français (é, è, à) = 2 bytes chacun
      // On utilise 6000 bytes pour permettre ~2000 caractères UTF-8
      allow create: if request.resource.data.keys().hasAll(['email', 'type', 'description'])
                    && request.resource.data.email is string
                    && request.resource.data.email.matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$')
                    && request.resource.data.type in ['bug', 'ux_friction', 'suggestion', 'other']
                    && request.resource.data.description is string
                    && request.resource.data.description.size() >= 10
                    && request.resource.data.description.size() <= 6000;
      // Mise à jour/Suppression: Admin uniquement
      allow update, delete: if isAdmin();
    }

    // ================= CAPI EVENTS (Meta Conversion API) =================
    // Événements Meta CAPI pour le tableau de bord analytics
    // Utilisé par: AdminMetaAnalytics, useMetaAnalytics hook
    match /capi_events/{eventId} {
      // Lecture: Admin uniquement (données analytiques sensibles)
      allow read: if isAdmin();
      // Écriture: Cloud Functions uniquement via Admin SDK
      allow create, update, delete: if false;
    }

    // ================= GOOGLE ADS EVENTS =================
    // Événements Google Ads Enhanced Conversions
    // Utilisé par: AdminGoogleAdsAnalytics, useGoogleAdsAnalytics hook
    match /google_ads_events/{eventId} {
      // Lecture: Admin uniquement
      allow read: if isAdmin();
      // Écriture: Cloud Functions uniquement via Admin SDK
      allow create, update, delete: if false;
    }

    // ================= COUPON USAGES =================
    // Historique d'utilisation des codes promo
    // Utilisé par: AdminPromoCodes pour les statistiques
    match /coupon_usages/{usageId} {
      // Lecture: Admin uniquement
      allow read: if isAdmin();
      // Écriture: Cloud Functions uniquement via Admin SDK
      allow create, update, delete: if false;
    }

    // ================= COUPON FAILED ATTEMPTS =================
    // m3 FIX: Tracking des tentatives de codes promo échouées (détection abus)
    // Écriture/Lecture: Cloud Functions uniquement via Admin SDK
    match /coupon_failed_attempts/{attemptId} {
      allow read, write: if false;
    }

    // ================= SCHEDULED REPORTS =================
    // Rapports planifiés pour Meta Analytics
    match /scheduled_reports/{reportId} {
      // Lecture/Écriture: Admin uniquement
      allow read, write: if isAdmin();
    }

    // ================= CONVERSATIONS (IA TOOL) =================
    // Historique des conversations IA entre clients et prestataires
    match /conversations/{conversationId} {
      // Lecture: client, provider concerné, agency_manager pour ses providers liés, ou admin
      // OUT-MUL-020 (audit 2026-05-03): aligné sur booking_requests qui utilise déjà
      // hasAgencyAccessToProvider — un agency_manager doit pouvoir voir les conversations
      // de SES providers liés (pas des autres) pour le multi-dashboard.
      allow read: if isAuthenticated() &&
                  (resource.data.clientId == request.auth.uid ||
                   resource.data.providerId == request.auth.uid ||
                   isAdmin() ||
                   hasAgencyAccessToProvider(resource.data.providerId));

      // Création: le clientId doit correspondre à l'utilisateur authentifié
      // P1 SECURITY FIX: Empêche l'usurpation d'identité dans les conversations
      allow create: if isAuthenticated() &&
                    request.resource.data.clientId == request.auth.uid;

      // Mise à jour: participants ou admin
      allow update: if isAuthenticated() &&
                    (resource.data.clientId == request.auth.uid ||
                     resource.data.providerId == request.auth.uid ||
                     isAdmin());

      // Suppression: admin seulement
      allow delete: if isAdmin();

      // Sous-collection messages
      match /messages/{messageId} {
        // Lecture: participants de la conversation parent (incl. agency_manager pour
        // ses providers liés, cohérence avec la rule parent)
        allow read: if isAuthenticated() &&
                    (get(/databases/$(database)/documents/conversations/$(conversationId)).data.clientId == request.auth.uid ||
                     get(/databases/$(database)/documents/conversations/$(conversationId)).data.providerId == request.auth.uid ||
                     isAdmin() ||
                     hasAgencyAccessToProvider(get(/databases/$(database)/documents/conversations/$(conversationId)).data.providerId));

        // Création: participants authentifiés
        allow create: if isAuthenticated() &&
                      (get(/databases/$(database)/documents/conversations/$(conversationId)).data.clientId == request.auth.uid ||
                       get(/databases/$(database)/documents/conversations/$(conversationId)).data.providerId == request.auth.uid ||
                       isAdmin());

        // Mise à jour/Suppression: admin seulement
        allow update, delete: if isAdmin();
      }
    }

    // ================= AFFILIATE SYSTEM =================
    // Configuration globale du système d'affiliation
    match /affiliate_config/{docId} {
      // Lecture: tous les utilisateurs authentifiés (pour afficher les taux)
      allow read: if isAuthenticated();
      // Écriture: admin seulement (via console admin)
      allow write: if isAdmin();
    }

    // Commissions d'affiliation
    match /affiliate_commissions/{commissionId} {
      // Lecture: le propriétaire (referrerId) ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.referrerId == request.auth.uid ||
                   isAdmin());
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // Demandes de retrait d'affiliation
    match /affiliate_payouts/{payoutId} {
      // Lecture: le propriétaire ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.userId == request.auth.uid ||
                   isAdmin());
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // Alertes de fraude d'affiliation
    match /affiliate_fraud_alerts/{alertId} {
      // Lecture et écriture: admin uniquement
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Statistiques quotidiennes d'affiliation
    match /affiliate_stats/{dateId} {
      // Lecture: admin uniquement
      allow read: if isAdmin();
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // Codes d'affiliation réservés
    match /affiliate_codes/{codeId} {
      // Lecture: tous les utilisateurs authentifiés (pour vérifier disponibilité)
      allow read: if isAuthenticated();
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // Historique des referrals (tracking)
    match /referrals/{referralId} {
      // Lecture: le referrer ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.referrerId == request.auth.uid ||
                   isAdmin());
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // ================= PARTNER SYSTEM =================

    // Partners : lecture par utilisateurs authentifiés (pour discount checkout)
    // Écriture : Cloud Functions uniquement (admin callables)
    match /partners/{partnerId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Partner commissions
    match /partner_commissions/{commissionId} {
      // Le partenaire peut lire ses propres commissions
      allow read: if isAuthenticated() &&
                  resource.data.partnerId == request.auth.uid;
      allow write: if false;
    }

    // Partner notifications
    match /partner_notifications/{notifId} {
      allow read: if isAuthenticated() &&
                  resource.data.partnerId == request.auth.uid;
      // Le partenaire peut marquer comme lue
      allow update: if isAuthenticated() &&
                    resource.data.partnerId == request.auth.uid &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt']);
      allow create, delete: if false;
    }

    // Partner config (admin)
    match /partner_config/{configId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Partner promo widgets
    match /partner_promo_widgets/{widgetId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ================= CHATTER SYSTEM =================
    // Système ambassadeurs/chatters avec gamification

    // Fonction helper pour vérifier si l'utilisateur est un chatter actif
    function isChatter() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/chatters/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/chatters/$(request.auth.uid)).data.status == 'active';
    }

    // Fonction pour vérifier si l'utilisateur est le propriétaire du chatter
    function isChatterOwner(chatterId) {
      return isAuthenticated() && request.auth.uid == chatterId;
    }

    // Fonction pour vérifier si l'utilisateur a un profil chatter actif
    // Note: pending_quiz supprimé (flow simplifié, activation immédiate)
    function hasChatterProfile() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/chatters/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/chatters/$(request.auth.uid)).data.status == 'active';
    }

    // Profils des chatters
    match /chatters/{chatterId} {
      // Lecture: propriétaire ou admin
      allow read: if isChatterOwner(chatterId) || isAdmin();
      // Création: propriétaire uniquement (lors de l'inscription)
      allow create: if isChatterOwner(chatterId);
      // Mise à jour: propriétaire pour certains champs, admin pour tous
      // Le propriétaire ne peut PAS modifier: status, level, codes, balances, stats
      allow update: if (isChatterOwner(chatterId) &&
                        !request.resource.data.diff(resource.data).affectedKeys()
                          .hasAny(['status', 'level', 'levelProgress',
                                   'affiliateCodeClient', 'affiliateCodeRecruitment',
                                   'totalEarned', 'availableBalance', 'pendingBalance',
                                   'validatedBalance', 'totalClients', 'totalRecruits',
                                   'totalCommissions', 'commissionsByType',
                                   'currentStreak', 'bestStreak', 'badges',
                                   'currentMonthRank', 'bestRank', 'quizPassedAt',
                                   'recruitedBy', 'recruitedByCode', 'recruitedAt',
                                   'role', 'captainPromotedAt', 'captainPromotedBy',
                                   'captainMonthlyTeamCalls', 'captainCurrentTier',
                                   'captainQualityBonusEnabled',
                                   'captainAssignedCountries', 'captainAssignedLanguages',
                                   'commissionPlanId', 'commissionPlanName',
                                   'rateLockDate', 'lockedRates']))
                       || isAdmin();
      allow delete: if isAdmin();

      // P0 FIX: Subcollection FCM tokens pour push notifications chatters
      match /fcmTokens/{tokenId} {
        allow read: if isChatterOwner(chatterId) || isAdmin();
        allow create, update: if isChatterOwner(chatterId);
        allow delete: if isChatterOwner(chatterId) || isAdmin();
      }
    }

    // Commissions des chatters
    match /chatter_commissions/{commissionId} {
      // Lecture: le propriétaire (chatterId) ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.chatterId == request.auth.uid ||
                   isAdmin());
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // Demandes de retrait des chatters
    match /chatter_withdrawals/{withdrawalId} {
      // Lecture: le propriétaire ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.chatterId == request.auth.uid ||
                   isAdmin());
      // Création: chatter actif pour son propre retrait
      allow create: if isChatter() &&
                    request.resource.data.chatterId == request.auth.uid;
      // Mise à jour: admin uniquement
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Commission Plans (Lifetime Rate Lock)
    match /commission_plans/{planId} {
      // Lecture: tout affilié authentifié ou admin (pour afficher les rates sur landing/dashboard)
      allow read: if isAuthenticated();
      // Écriture: admin uniquement (CRUD des plans)
      allow write: if isAdmin();
    }

    // Configuration du système chatter
    match /chatter_config/{docId} {
      // Lecture: doc 'current' public (landing pages dynamiques) + chatters/admin pour le reste
      allow read: if docId == 'current' || isChatter() || isAdmin();
      // Écriture: admin uniquement
      allow write: if isAdmin();
    }

    // Questions du quiz chatter (legacy collection — quiz removed, kept for historical data)
    match /chatter_quiz_questions/{questionId} {
      // Lecture: chatters actifs ou admin
      allow read: if hasChatterProfile() || isAdmin();
      // Écriture: admin uniquement
      allow write: if isAdmin();
    }

    // Tentatives de quiz
    match /chatter_quiz_attempts/{attemptId} {
      // Lecture: le propriétaire ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.chatterId == request.auth.uid ||
                   isAdmin());
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // Définitions des badges
    match /chatter_badges/{badgeId} {
      // Lecture: tous les utilisateurs authentifiés
      allow read: if isAuthenticated();
      // Écriture: admin uniquement
      allow write: if isAdmin();
    }

    // Attribution des badges
    match /chatter_badge_awards/{awardId} {
      // Lecture: le propriétaire ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.chatterId == request.auth.uid ||
                   isAdmin());
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // Classements mensuels
    match /chatter_monthly_rankings/{monthId} {
      // Lecture: tous les chatters et admin
      allow read: if isChatter() || isAdmin();
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // Plateformes
    match /chatter_platforms/{platformId} {
      // Lecture: tous les utilisateurs authentifiés
      allow read: if isAuthenticated();
      // Écriture: admin uniquement
      allow write: if isAdmin();
    }

    // Tracking des clics affiliés
    match /chatter_affiliate_clicks/{clickId} {
      // Lecture: admin uniquement (données sensibles)
      allow read: if isAdmin();
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // Liens de recrutement
    match /chatter_recruitment_links/{linkId} {
      // Lecture: le propriétaire ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.chatterId == request.auth.uid ||
                   isAdmin());
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // Notifications des chatters
    match /chatter_notifications/{notificationId} {
      // Lecture: le propriétaire ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.chatterId == request.auth.uid ||
                   isAdmin());
      // Mise à jour: le propriétaire peut marquer comme lu
      allow update: if isAuthenticated() &&
                    resource.data.chatterId == request.auth.uid &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'readAt']);
      // Création/suppression: Cloud Functions uniquement
      allow create, delete: if false;
    }

    // Réunions Zoom
    match /chatter_zoom_meetings/{meetingId} {
      // Lecture: chatters actifs et admin
      allow read: if isChatter() || isAdmin();
      // Écriture: admin uniquement
      allow write: if isAdmin();
    }

    // Présences Zoom
    match /chatter_zoom_attendance/{attendanceId} {
      // Lecture: le propriétaire ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.chatterId == request.auth.uid ||
                   isAdmin());
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // Posts des chatters (pour modération)
    match /chatter_posts/{postId} {
      // Lecture: le propriétaire ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.chatterId == request.auth.uid ||
                   isAdmin());
      // Création: chatter actif
      allow create: if isChatter() &&
                    request.resource.data.chatterId == request.auth.uid;
      // Mise à jour: admin uniquement (modération)
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Groupes/Forums des chatters
    match /chatter_groups/{groupId} {
      // Lecture: tous les chatters actifs ou admin
      allow read: if isChatter() || isAdmin();
      // Création: chatter actif uniquement
      allow create: if isChatter() &&
                    request.resource.data.submittedBy == request.auth.uid;
      // Mise à jour: admin uniquement (modération status)
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Activités dans les groupes chatters
    match /chatter_groups/{groupId}/activities/{activityId} {
      // Lecture: chatters ou admin
      allow read: if isChatter() || isAdmin();
      // Création: chatter qui rejoint le groupe
      allow create: if isChatter() &&
                    request.resource.data.chatterId == request.auth.uid;
      // Mise à jour/suppression: admin uniquement
      allow update, delete: if isAdmin();
    }

    // Alertes de fraude des chatters
    match /chatter_fraud_alerts/{alertId} {
      // Lecture et écriture: admin uniquement
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Commissions de parrainage des chatters (N1/N2)
    match /chatter_referral_commissions/{commissionId} {
      // Lecture: le propriétaire (parrainId) ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.parrainId == request.auth.uid ||
                   isAdmin());
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // Historique des bonus de palier
    match /chatter_tier_bonuses_history/{historyId} {
      // Lecture: le propriétaire (chatterId) ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.chatterId == request.auth.uid ||
                   isAdmin());
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // Compteurs early adopter par pays
    match /chatter_early_adopter_counters/{counterId} {
      // Lecture publique: landing page affiche les places restantes
      allow read: if true;
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // Promotions et multiplicateurs
    match /chatter_promotions/{promoId} {
      // Lecture: tous les chatters actifs et admin
      allow read: if isChatter() || isAdmin();
      // Écriture: admin uniquement
      allow write: if isAdmin();
    }

    // Likes sociaux (anti-fraude, admin uniquement)
    match /chatter_social_likes/{likeId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Défis hebdomadaires
    match /chatter_weekly_challenges/{challengeId} {
      allow read: if isChatter() || isAdmin();
      allow write: if isAdmin();
    }

    // P0 FIX: Compteurs d'appels chatters (anti-fraude, bonus activation)
    match /chatter_call_counts/{chatterId} {
      // Lecture: le propriétaire (pour voir son compteur) ou admin
      allow read: if isChatterOwner(chatterId) || isAdmin();
      // Écriture: Cloud Functions uniquement (triggers onCallCompleted)
      allow write: if false;
    }

    // P0 FIX: Reviews de fraude chatters (modération manuelle)
    match /chatter_fraud_reviews/{reviewId} {
      // Lecture: admin uniquement (données sensibles de fraude)
      allow read: if isAdmin();
      // Écriture: Cloud Functions pour créer, admin pour résoudre
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // P0 FIX: Modules de formation chatters
    match /chatter_training_modules/{moduleId} {
      // Lecture: chatters actifs (pour suivre la formation) ou admin
      allow read: if isChatter() || isAdmin();
      // Écriture: admin uniquement (gestion du contenu)
      allow write: if isAdmin();
    }

    // P0 FIX: Progression formation chatters
    match /chatter_training_progress/{progressId} {
      // Lecture: le propriétaire (chatterId) ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.chatterId == request.auth.uid ||
                   isAdmin());
      // Écriture: Admin SDK (Cloud Functions) uniquement
      allow write: if false;

      // Sous-collection modules — structure réelle: chatter_training_progress/{userId}/modules/{moduleId}
      match /modules/{moduleId} {
        // Lecture: l'utilisateur propriétaire (progressId == uid) ou admin
        allow read: if isAuthenticated() &&
                    (progressId == request.auth.uid || isAdmin());
        // Écriture: Admin SDK (Cloud Functions) uniquement — les callables utilisent initializeApp()
        allow write: if false;
      }
    }

    // P0 FIX: Certificats de formation chatters
    match /chatter_training_certificates/{certId} {
      // Lecture: le propriétaire (chatterId) ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.chatterId == request.auth.uid ||
                   isAdmin());
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // P0 FIX: Archives mensuelles Captain Chatter
    match /captain_monthly_archives/{archiveId} {
      // Lecture: admin uniquement (données agrégées)
      allow read: if isAdmin();
      // Écriture: Cloud Functions uniquement (cron mensuel)
      allow write: if false;
    }

    // P0 FIX: Messages drip chatters (onboarding Telegram)
    match /chatter_drip_messages/{messageId} {
      // Lecture: admin (gestion des templates)
      allow read: if isAdmin();
      // Écriture: admin uniquement (configuration)
      allow write: if isAdmin();
    }

    // P0 FIX: Prestataires recrutés par chatters
    match /chatter_recruited_providers/{recruitId} {
      // Lecture: le chatter recruteur ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.chatterId == request.auth.uid ||
                   isAdmin());
      // Écriture: Cloud Functions uniquement (trigger onProviderRegistered)
      allow write: if false;
    }

    // ================= INFLUENCER SYSTEM =================
    // Règles pour le programme influenceurs (parrainage clients + recrutement prestataires)
    // NOTE: Différent des Chatters - pas de quiz, pas de niveaux, commissions fixes

    // Helper: est un influenceur actif
    function isInfluencer() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/influencers/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/influencers/$(request.auth.uid)).data.status == 'active';
    }

    // Helper: est le propriétaire du profil influenceur
    function isInfluencerOwner(influencerId) {
      return isAuthenticated() && request.auth.uid == influencerId;
    }

    // Helper: a un profil influenceur (peu importe le status)
    function hasInfluencerProfile() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/influencers/$(request.auth.uid));
    }

    // Profils des influenceurs
    match /influencers/{influencerId} {
      // Lecture: propriétaire ou admin
      allow read: if isInfluencerOwner(influencerId) || isAdmin();
      // Création: propriétaire uniquement (lors de l'inscription)
      allow create: if isInfluencerOwner(influencerId);
      // Mise à jour: propriétaire pour certains champs, admin pour tous
      // Le propriétaire ne peut PAS modifier: status, codes, balances, stats, ranks
      allow update: if (isInfluencerOwner(influencerId) &&
                        !request.resource.data.diff(resource.data).affectedKeys()
                          .hasAny(['status', 'affiliateCodeClient', 'affiliateCodeRecruitment',
                                   'totalEarned', 'availableBalance', 'pendingBalance',
                                   'validatedBalance', 'totalClients', 'totalRecruits',
                                   'totalCommissions', 'currentMonthStats',
                                   'currentMonthRank', 'bestRank', 'adminNotes',
                                   'commissionPlanId', 'commissionPlanName',
                                   'rateLockDate', 'lockedRates']))
                       || isAdmin();
      allow delete: if isAdmin();
    }

    // Commissions influenceurs
    match /influencer_commissions/{commissionId} {
      // Lecture: propriétaire de la commission ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.influencerId == request.auth.uid ||
                   isAdmin());
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // Retraits influenceurs
    match /influencer_withdrawals/{withdrawalId} {
      // Lecture: propriétaire ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.influencerId == request.auth.uid ||
                   isAdmin());
      // Création: influenceur actif pour lui-même
      allow create: if isInfluencer() &&
                    request.resource.data.influencerId == request.auth.uid;
      // Mise à jour: admin uniquement (approbation/rejet)
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Filleuls/recrutements influenceurs (prestataires recrutés)
    match /influencer_referrals/{referralId} {
      // Lecture: propriétaire ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.influencerId == request.auth.uid ||
                   isAdmin());
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // Configuration du système influenceur
    match /influencer_config/{docId} {
      // Lecture: doc 'current' public (landing pages dynamiques) + influenceurs/admin pour le reste
      allow read: if docId == 'current' || isInfluencer() || isAdmin();
      // Écriture: admin uniquement
      allow write: if isAdmin();
    }

    // Classement mensuel influenceurs
    match /influencer_monthly_rankings/{monthId} {
      // Lecture: tous les influenceurs et admin
      allow read: if isInfluencer() || isAdmin();
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // Notifications influenceurs
    match /influencer_notifications/{notificationId} {
      // Lecture: le propriétaire ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.influencerId == request.auth.uid ||
                   isAdmin());
      // Mise à jour: le propriétaire peut marquer comme lu
      allow update: if isAuthenticated() &&
                    resource.data.influencerId == request.auth.uid &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'readAt']);
      // Création/suppression: Cloud Functions uniquement
      allow create, delete: if false;
    }

    // Clics affiliés influenceurs (tracking)
    match /influencer_affiliate_clicks/{clickId} {
      // Lecture: admin uniquement
      allow read: if isAdmin();
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // Bannières widgets (outils promotionnels)
    match /widget_banners/{bannerId} {
      // Lecture: influenceurs actifs et admin
      allow read: if isInfluencer() || isAdmin();
      // Écriture: admin uniquement
      allow write: if isAdmin();
    }

    // Textes promotionnels widgets
    match /widget_texts/{textId} {
      // Lecture: influenceurs actifs et admin
      allow read: if isInfluencer() || isAdmin();
      // Écriture: admin uniquement
      allow write: if isAdmin();
    }

    // Ressources influenceurs (guides, templates, matériel promotionnel)
    match /influencer_resources/{resourceId} {
      allow read: if isInfluencer() || isAdmin();
      allow write: if isAdmin();
    }

    // ================= BLOGGERS (Programme Partenaire Blogueurs) =================
    // Commissions FIXES: 10$ client, 5$ recrutement (pas de bonus/multiplicateur)
    // Pas de niveaux, pas de quiz, rôle DÉFINITIF, ressources et guide EXCLUSIFS

    // Helper: est un blogueur actif
    function isBlogger() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/bloggers/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/bloggers/$(request.auth.uid)).data.status == 'active';
    }

    // Helper: est le propriétaire du profil blogueur
    function isBloggerOwner(bloggerId) {
      return isAuthenticated() && request.auth.uid == bloggerId;
    }

    // Helper: a un profil blogueur (peu importe le status)
    function hasBloggerProfile() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/bloggers/$(request.auth.uid));
    }

    // Profils des blogueurs
    match /bloggers/{bloggerId} {
      // Lecture: propriétaire ou admin
      allow read: if isBloggerOwner(bloggerId) || isAdmin();
      // Création: propriétaire uniquement (lors de l'inscription)
      allow create: if isBloggerOwner(bloggerId);
      // Mise à jour: propriétaire pour certains champs, admin pour tous
      // Le propriétaire ne peut PAS modifier: status, codes, balances, stats, ranks
      allow update: if (isBloggerOwner(bloggerId) &&
                        !request.resource.data.diff(resource.data).affectedKeys()
                          .hasAny(['status', 'affiliateCodeClient', 'affiliateCodeRecruitment',
                                   'totalEarned', 'availableBalance', 'pendingBalance',
                                   'validatedBalance', 'totalClients', 'totalRecruits',
                                   'totalCommissions', 'currentMonthStats',
                                   'currentMonthRank', 'bestRank', 'adminNotes',
                                   'commissionPlanId', 'commissionPlanName',
                                   'rateLockDate', 'lockedRates']))
                       || isAdmin();
      allow delete: if isAdmin();
    }

    // Commissions blogueurs
    match /blogger_commissions/{commissionId} {
      // Lecture: propriétaire de la commission ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.bloggerId == request.auth.uid ||
                   isAdmin());
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // Retraits blogueurs
    match /blogger_withdrawals/{withdrawalId} {
      // Lecture: propriétaire ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.bloggerId == request.auth.uid ||
                   isAdmin());
      // Création: blogueur actif pour lui-même
      allow create: if isBlogger() &&
                    request.resource.data.bloggerId == request.auth.uid;
      // Mise à jour: admin uniquement (approbation/rejet)
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Prestataires recrutés par blogueurs
    match /blogger_recruited_providers/{recruitmentId} {
      // Lecture: propriétaire ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.bloggerId == request.auth.uid ||
                   isAdmin());
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // Configuration du système blogueur
    match /blogger_config/{docId} {
      // Lecture: doc 'current' public (landing pages dynamiques) + blogueurs/admin pour le reste
      allow read: if docId == 'current' || isBlogger() || isAdmin();
      // Écriture: admin uniquement
      allow write: if isAdmin();
    }

    // Classement mensuel blogueurs
    match /blogger_monthly_rankings/{monthId} {
      // Lecture: tous les blogueurs et admin
      allow read: if isBlogger() || isAdmin();
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // Notifications blogueurs
    match /blogger_notifications/{notificationId} {
      // Lecture: le propriétaire ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.bloggerId == request.auth.uid ||
                   isAdmin());
      // Mise à jour: le propriétaire peut marquer comme lu
      allow update: if isAuthenticated() &&
                    resource.data.bloggerId == request.auth.uid &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'readAt']);
      // Création/suppression: Cloud Functions uniquement
      allow create, delete: if false;
    }

    // Clics affiliés blogueurs (tracking)
    match /blogger_clicks/{clickId} {
      // Lecture: admin uniquement
      allow read: if isAdmin();
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // Badges blogueurs (définitions)
    match /blogger_badges/{badgeId} {
      // Lecture: blogueurs et admin
      allow read: if isBlogger() || isAdmin();
      // Écriture: admin uniquement
      allow write: if isAdmin();
    }

    // Ressources blogueurs (fichiers - EXCLUSIF)
    match /blogger_resources/{resourceId} {
      // Lecture: blogueurs actifs et admin
      allow read: if isBlogger() || isAdmin();
      // Écriture: admin uniquement
      allow write: if isAdmin();
    }

    // Ressources blogueurs (textes - EXCLUSIF)
    match /blogger_resource_texts/{textId} {
      // Lecture: blogueurs actifs et admin
      allow read: if isBlogger() || isAdmin();
      // Écriture: admin uniquement
      allow write: if isAdmin();
    }

    // Guide blogueurs - Templates (EXCLUSIF)
    match /blogger_guide_templates/{templateId} {
      // Lecture: blogueurs actifs et admin
      allow read: if isBlogger() || isAdmin();
      // Écriture: admin uniquement
      allow write: if isAdmin();
    }

    // Guide blogueurs - Textes à copier (EXCLUSIF)
    match /blogger_guide_copy_texts/{textId} {
      // Lecture: blogueurs actifs et admin
      allow read: if isBlogger() || isAdmin();
      // Écriture: admin uniquement
      allow write: if isAdmin();
    }

    // Guide blogueurs - Bonnes pratiques (EXCLUSIF)
    match /blogger_guide_best_practices/{practiceId} {
      // Lecture: blogueurs actifs et admin
      allow read: if isBlogger() || isAdmin();
      // Écriture: admin uniquement
      allow write: if isAdmin();
    }

    // Logs d'utilisation blogueurs (tracking ressources/guide)
    match /blogger_usage_logs/{logId} {
      // Lecture: admin uniquement
      allow read: if isAdmin();
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // ================= GROUP ADMINS (Administrateurs Groupes Facebook) =================
    // Programme affilié pour admins de groupes FB: $15/client, $5/admin recruté
    // Posts et ressources prêts à l'emploi, gamification (badges, leaderboard)

    // Helper: est un GroupAdmin actif
    function isGroupAdmin() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/group_admins/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/group_admins/$(request.auth.uid)).data.status == 'active';
    }

    // Helper: est le propriétaire du profil GroupAdmin
    function isGroupAdminOwner(groupAdminId) {
      return isAuthenticated() && request.auth.uid == groupAdminId;
    }

    // Helper: a un profil GroupAdmin (peu importe le status)
    function hasGroupAdminProfile() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/group_admins/$(request.auth.uid));
    }

    // Profils des GroupAdmins
    match /group_admins/{groupAdminId} {
      // Lecture: propriétaire ou admin
      allow read: if isGroupAdminOwner(groupAdminId) || isAdmin();
      // Création: propriétaire uniquement (lors de l'inscription)
      allow create: if isGroupAdminOwner(groupAdminId);
      // Mise à jour: propriétaire pour certains champs, admin pour tous
      // Le propriétaire ne peut PAS modifier: status, codes, balances, stats, ranks, adminNotes
      allow update: if (isGroupAdminOwner(groupAdminId) &&
                        !request.resource.data.diff(resource.data).affectedKeys()
                          .hasAny(['status', 'affiliateCodeClient', 'affiliateCodeRecruitment',
                                   'totalEarned', 'availableBalance', 'pendingBalance',
                                   'validatedBalance', 'totalWithdrawn', 'totalClients',
                                   'totalRecruits', 'totalCommissions', 'currentMonthStats',
                                   'currentMonthRank', 'bestRank', 'badges', 'adminNotes',
                                   'isGroupVerified', 'groupVerifiedAt', 'suspensionReason',
                                   'commissionPlanId', 'commissionPlanName',
                                   'rateLockDate', 'lockedRates']))
                       || isAdmin();
      allow delete: if isAdmin();
    }

    // Commissions GroupAdmins
    match /group_admin_commissions/{commissionId} {
      // Lecture: propriétaire de la commission ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.groupAdminId == request.auth.uid ||
                   isAdmin());
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // Retraits GroupAdmins
    match /group_admin_withdrawals/{withdrawalId} {
      // Lecture: propriétaire ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.groupAdminId == request.auth.uid ||
                   isAdmin());
      // Création: GroupAdmin actif pour lui-même
      allow create: if isGroupAdmin() &&
                    request.resource.data.groupAdminId == request.auth.uid;
      // Mise à jour: admin uniquement (approbation/rejet)
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Admins recrutés par GroupAdmins
    match /group_admin_recruited_admins/{recruitId} {
      // Lecture: propriétaire (recruteur) ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.recruiterId == request.auth.uid ||
                   isAdmin());
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // Prestataires (avocats/expats) recrutés par GroupAdmins
    match /group_admin_recruited_providers/{recruitId} {
      // Lecture: propriétaire (groupAdminId) ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.groupAdminId == request.auth.uid ||
                   isAdmin());
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // Tracking clics affiliés GroupAdmins
    match /group_admin_affiliate_clicks/{clickId} {
      // Lecture: admin uniquement (données sensibles)
      allow read: if isAdmin();
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // Tracking clics affiliés Bloggers
    match /blogger_affiliate_clicks/{clickId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Tracking clics affiliés Partners
    match /partner_affiliate_clicks/{clickId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Notifications GroupAdmins
    match /group_admin_notifications/{notificationId} {
      // Lecture: le propriétaire ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.groupAdminId == request.auth.uid ||
                   isAdmin());
      // Mise à jour: le propriétaire peut marquer comme lu
      allow update: if isAuthenticated() &&
                    resource.data.groupAdminId == request.auth.uid &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'readAt']);
      // Création/suppression: Cloud Functions uniquement
      allow create, delete: if false;
    }

    // Ressources GroupAdmins (images, bannières, etc.)
    match /group_admin_resources/{resourceId} {
      // Lecture: GroupAdmins actifs et admin
      allow read: if isGroupAdmin() || isAdmin();
      // Écriture: admin uniquement
      allow write: if isAdmin();
    }

    // Textes des ressources GroupAdmins
    match /group_admin_resource_texts/{textId} {
      // Lecture: GroupAdmins actifs et admin
      allow read: if isGroupAdmin() || isAdmin();
      // Écriture: admin uniquement
      allow write: if isAdmin();
    }

    // Posts Facebook prêts à l'emploi
    match /group_admin_posts/{postId} {
      // Lecture: GroupAdmins actifs et admin
      allow read: if isGroupAdmin() || isAdmin();
      // Écriture: admin uniquement
      allow write: if isAdmin();
    }

    // Définitions des badges GroupAdmins
    match /group_admin_badges/{badgeId} {
      // Lecture: GroupAdmins et admin
      allow read: if isGroupAdmin() || isAdmin();
      // Écriture: admin uniquement
      allow write: if isAdmin();
    }

    // Attribution des badges GroupAdmins
    match /group_admin_badge_awards/{awardId} {
      // Lecture: le propriétaire ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.groupAdminId == request.auth.uid ||
                   isAdmin());
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // Classements mensuels GroupAdmins
    match /group_admin_monthly_rankings/{monthId} {
      // Lecture: tous les GroupAdmins et admin
      allow read: if isGroupAdmin() || isAdmin();
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // Configuration du système GroupAdmin
    match /group_admin_config/{docId} {
      // Lecture: doc 'current' public (landing pages dynamiques) + GroupAdmins/admin pour le reste
      allow read: if docId == 'current' || isGroupAdmin() || isAdmin();
      // Écriture: admin uniquement
      allow write: if isAdmin();
    }

    // Logs d'utilisation GroupAdmins (tracking ressources/posts)
    match /group_admin_usage_log/{logId} {
      // Lecture: admin uniquement
      allow read: if isAdmin();
      // Écriture: Cloud Functions uniquement
      allow write: if false;
    }

    // ================= LAWYERS COLLECTION =================
    // Collection utilisée par Stripe KYC (getAccountSession)
    match /lawyers/{lawyerId} {
      allow read: if (isAuthenticated() && isOwner(lawyerId)) || isAdmin();
      allow create: if isAuthenticated() && isOwner(lawyerId);
      allow update: if (isOwner(lawyerId) &&
                        !request.resource.data.diff(resource.data).affectedKeys()
                          .hasAny(['stripeAccountId', 'stripeAccountStatus']))
                       || isAdmin();
      allow delete: if isAdmin();
    }

    // ================= EXPATS COLLECTION =================
    // Collection utilisée par Stripe KYC (getAccountSession)
    match /expats/{expatId} {
      allow read: if (isAuthenticated() && isOwner(expatId)) || isAdmin();
      allow create: if isAuthenticated() && isOwner(expatId);
      allow update: if (isOwner(expatId) &&
                        !request.resource.data.diff(resource.data).affectedKeys()
                          .hasAny(['stripeAccountId', 'stripeAccountStatus']))
                       || isAdmin();
      allow delete: if isAdmin();
    }

    // ================= BLOGGER PROMO WIDGETS =================
    match /blogger_promo_widgets/{widgetId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ================= REFUND REQUESTS =================
    match /refund_requests/{requestId} {
      allow read: if isAuthenticated() &&
                  (resource.data.userId == request.auth.uid ||
                   resource.data.clientId == request.auth.uid ||
                   isAdmin());
      allow write: if isAdmin();
    }

    // ================= PLATFORM COSTS (Finance) =================
    match /platform_costs/{costId} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Functions uniquement
    }

    // ================= TWILIO USAGE (Finance) =================
    match /twilio_usage/{usageId} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Functions uniquement
    }

    // ================= FINANCE EXPORTS =================
    match /finance_exports/{exportId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // ================= RECONCILIATION LOGS =================
    match /reconciliation_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // ================= AI USAGE LOGS =================
    match /ai_usage_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Functions uniquement
    }

    // ================= CALL ERRORS =================
    match /call_errors/{errorId} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Functions uniquement
    }

    // ================= APP SETTINGS =================
    // Parametres globaux de l'application (AdminSettings)
    match /app_settings/{docId} {
      // Lecture: admin uniquement
      allow read: if isAdmin();
      // Ecriture: admin uniquement
      allow write: if isAdmin();
    }

    // ================= CALL LOGS =================
    // Logs des appels (audit et monitoring)
    match /call_logs/{logId} {
      // Lecture: admin uniquement
      allow read: if isAdmin();
      // Creation: utilisateurs authentifies (logging)
      allow create: if isAuthenticated();
      // Modification/suppression: Cloud Functions uniquement
      allow update, delete: if false;
    }

    // ================= REVIEW REPORTS =================
    // Signalements d'avis
    match /review_reports/{reportId} {
      // Lecture: admin uniquement
      allow read: if isAdmin();
      // Creation: utilisateurs authentifies
      allow create: if isAuthenticated();
      // Modification/suppression: admin uniquement
      allow update, delete: if isAdmin();
    }

    // ================= CHATTER ACTIVITY FEED =================
    // Flux d'activite en temps reel des chatters
    match /chatter_activity_feed/{feedId} {
      // Lecture: chatters actifs et admin
      allow read: if isChatter() || isAdmin();
      // Ecriture: Cloud Functions uniquement
      allow write: if false;
    }

    // ================= TAX RATES =================
    // Taux de taxes par pays/region
    match /tax_rates/{rateId} {
      // Lecture: utilisateurs authentifies (calculs de prix)
      allow read: if isAuthenticated();
      // Ecriture: admin uniquement
      allow write: if isAdmin();
    }

    // ================= TELEGRAM ONBOARDING LINKS =================
    // Liens d'onboarding Telegram pour chatters/influencers/bloggers/groupAdmins
    match /telegram_onboarding_links/{linkId} {
      // Lecture: admin ou proprietaire du lien
      allow read: if isAuthenticated() &&
                  (resource.data.userId == request.auth.uid || isAdmin());
      // Ecriture: Cloud Functions uniquement (via Admin SDK)
      allow write: if false;
    }

    // ================= COUNTRY LANDING CONFIGS =================
    // Landing page configs per country (payments, currency, testimonials, SEO)
    match /country_landing_configs/{configId} {
      allow read: if true;          // Landing pages are public
      allow write: if isAdmin();    // Only admins can edit
    }

    // ================= MESSAGE TEMPLATES =================
    // Templates de messages pour l'admin comms UI
    match /message_templates/{locale} {
      allow read: if isAdmin();
      allow write: if isAdmin();

      match /items/{itemId} {
        allow read: if isAdmin();
        allow write: if isAdmin();
      }
    }

    // ================= PAYMENT WITHDRAWALS =================
    // Retraits centralisés (chatters, influenceurs, blogueurs, groupAdmins, providers)
    match /payment_withdrawals/{withdrawalId} {
      // Lecture: propriétaire ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.userId == request.auth.uid || isAdmin());
      // Écriture: Cloud Functions uniquement (via Admin SDK)
      allow write: if false;
    }

    // ================= PAYMENT METHODS =================
    // Méthodes de paiement (PayPal, virement, etc.)
    match /payment_methods/{methodId} {
      // Lecture: propriétaire ou admin
      allow read: if isAuthenticated() &&
                  (resource.data.userId == request.auth.uid || isAdmin());
      // Écriture: Cloud Functions uniquement (via Admin SDK)
      allow write: if false;
    }

    // ================= PAYMENT WEBHOOK LOGS =================
    // Logs des webhooks de paiement (PayPal, Wise, etc.)
    match /payment_webhook_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ================= PAYMENT AUDIT LOGS =================
    // Logs d'audit des paiements
    match /payment_audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ================= PROVIDER STATS =================
    // Statistiques mensuelles des prestataires
    // AJOUT 2026-02-12: Les agency_managers peuvent lire les stats de leurs providers liés
    match /provider_stats/{statId} {
      allow read: if isAdmin() ||
                     hasAgencyAccessToProvider(resource.data.providerId);
      allow write: if false;
    }

    // ================= CHATTER RECRUITED CHATTERS =================
    // Chatters recrutés par d'autres chatters (N1/N2)
    match /chatter_recruited_chatters/{recruitId} {
      allow read: if isAuthenticated() &&
                  (resource.data.recruiterId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // ================= BLOGGER RECRUITED BLOGGERS =================
    // Blogueurs recrutés par d'autres blogueurs
    match /blogger_recruited_bloggers/{recruitId} {
      allow read: if isAuthenticated() &&
                  (resource.data.recruiterId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // ================= CHATTER IP REGISTRY =================
    // Registre IP pour détection fraude chatters
    match /chatter_ip_registry/{registryId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ================= CHATTER REFERRAL FRAUD ALERTS =================
    // Alertes de fraude sur les parrainages chatters
    match /chatter_referral_fraud_alerts/{alertId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ================= STRIPE SYNC LOGS =================
    // Logs de synchronisation Stripe
    match /stripe_sync_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ================= DUNNING RECORDS =================
    // Enregistrements de relance (dunning) pour paiements échoués
    match /dunning_records/{recordId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ================= TELEGRAM MESSAGE QUEUE =================
    // Queue globale de messages Telegram - Cloud Functions uniquement
    match /telegram_message_queue/{messageId} {
      allow read, write: if false;
    }

    // ================= TELEGRAM RATE MONITOR =================
    // Compteurs journaliers d'envoi Telegram - admin lecture seule
    match /telegram_rate_monitor/{dateId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ================= TELEGRAM SUBSCRIBER STATS =================
    // Stats subscribers Telegram - admin lecture seule
    match /telegram_subscriber_stats/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ================= TELEGRAM ADMIN CONFIG =================
    // Configuration admin du bot Telegram - admin lecture seule
    match /telegram_admin_config/{configId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ================= TELEGRAM ADMIN TEMPLATES =================
    // Templates de notification Telegram - admin lecture seule
    match /telegram_admin_templates/{templateId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ================= TELEGRAM ADMIN LOGS =================
    // Logs de notification Telegram - admin lecture seule
    match /telegram_admin_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ================= TELEGRAM CAMPAIGNS =================
    // Campagnes Telegram - admin lecture seule
    match /telegram_campaigns/{campaignId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ================= P0 FIX: FRAUD ALERTS (centralisé, multi-source) =================
    // Alertes de fraude centralisées (chatter, affiliate, referral)
    match /fraud_alerts/{alertId} {
      // Lecture: admin uniquement (données sensibles)
      allow read: if isAdmin();
      // Écriture: Cloud Functions uniquement (fraud detection system)
      // Admin peut résoudre (update status/resolution)
      allow create, delete: if false;
      allow update: if isAdmin();
    }

    // ================= P0 FIX: AGENT ORCHESTRATION (système interne) =================
    // État des agents IA (BaseAgent orchestration)
    match /agent_states/{agentId} {
      // Lecture/écriture: Cloud Functions uniquement (orchestration interne)
      allow read, write: if false;
    }

    // Tâches des agents IA (BaseAgent task queue)
    match /agent_tasks/{taskId} {
      // Lecture/écriture: Cloud Functions uniquement (orchestration interne)
      allow read, write: if false;
    }

    // ================= P0 FIX: ROLE RESTORATION LOGS (audit admin) =================
    // Logs de restauration des rôles utilisateurs
    match /role_restoration_logs/{logId} {
      // Lecture: admin uniquement (audit trail)
      allow read: if isAdmin();
      // Écriture: Cloud Functions uniquement (callable admin)
      allow write: if false;
    }

    // ================= AFFILIATE NOTIFICATIONS =================
    // P1-6 SECURITY FIX: Règle manquante — collection utilisée par onCallCompleted
    match /affiliate_notifications/{notifId} {
      allow read: if isAuthenticated() &&
                  (resource.data.affiliateId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // ================= FORFEITED FUNDS =================
    // P1-6 SECURITY FIX: Règle manquante — collection utilisée par admin callables
    match /forfeited_funds/{fundId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ================= PAYPAL VERIFICATION CODES =================
    // P1-6 SECURITY FIX: Règle manquante — collection utilisée par emailVerification
    match /paypal_verification_codes/{codeId} {
      allow read: if isAuthenticated() &&
                  (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // ================= TRANSFER RETRY LOGS =================
    // P1-6 SECURITY FIX: Règle manquante — collection utilisée par stripeTransferRetryTasks
    match /transfer_retry_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ================= CAPTAIN APPLICATIONS (public recruitment) =================
    // Candidatures Capitaines - ecriture publique (landing page), lecture/update/delete admin only
    match /captain_applications/{applicationId} {
      // Create: anyone can submit a captain application (landing page, no auth)
      allow create: if request.resource.data.keys().hasAll(['name', 'whatsapp', 'country', 'status'])
                    && request.resource.data.keys().hasOnly(['name', 'whatsapp', 'country', 'status', 'motivation', 'cvUrl', 'photoUrl', 'source', 'language', 'createdAt'])
                    && request.resource.data.status == 'pending'
                    && request.resource.data.whatsapp is string
                    && request.resource.data.whatsapp.size() > 0
                    && request.resource.data.whatsapp.matches('^\\+[1-9][0-9]{6,14}$');
      // Read, update, delete: admin only
      allow read, update, delete: if isAdmin();
    }

    // ================= PARTNER APPLICATIONS =================
    // Candidatures Partenaires - formulaire public (pas de connexion requise)
    // Anti-spam: rate limit par email dans le document (max 3 candidatures par email, vérifié côté backend)
    match /partner_applications/{applicationId} {
      allow read, update, delete: if isAdmin();
      allow create: if true
        && request.resource.data.keys().hasAll(['email', 'name', 'createdAt'])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 5
        && request.resource.data.email.size() < 255
        && request.resource.data.name is string
        && request.resource.data.name.size() > 1
        && request.resource.data.name.size() < 200;
    }

    match /ssr_cache/{docId} {
      allow read: if true;   // Cache public pour les bots
      allow write: if false; // Cloud Functions Admin SDK uniquement
    }

    // ================= PRESS RELEASES =================
    // Communiqués de presse — lecture publique si isActive=true
    match /press_releases/{releaseId} {
      allow read: if resource.data.isActive == true;
      allow create, update, delete: if isAdmin();
    }

    // ================= PRESS DOWNLOADS =================
    // Tracking des téléchargements presse — création publique, admin lecture
    match /press_downloads/{dlId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ================= BLOGGER RELEASES =================
    // Communiqués pour blogueurs — lecture publique si isActive=true
    match /blogger_releases/{releaseId} {
      allow read: if resource.data.isActive == true;
      allow create, update, delete: if isAdmin();
    }

    // ================= GROUP ADMIN RELEASES =================
    // Communiqués pour admins de groupes — lecture publique si isActive=true
    match /group_admin_releases/{releaseId} {
      allow read: if resource.data.isActive == true;
      allow create, update, delete: if isAdmin();
    }

    // ================= CATCH-ALL (deny by default) =================
    // SECURITE: Refuse TOUT acces non explicitement autorise
    // Le role 'dev' est desactive en production
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
