# ================================
# Dépendances
# ================================
node_modules/
**/node_modules/
package-lock.json

# ================================
# Builds / artefacts
# ================================
/dist/
/dist-ssr/
/build/
/.vite/
**/.vite/
coverage/
*.tsbuildinfo

# ================================
# Environnements & secrets
# ================================
.env
.env.*
!.env.example

# fichiers de clés & credentials sensibles
**/serviceAccount.json
**/service-account.json
**/serviceAccount*.json
**/*-adminsdk-*.json
**/*.p12
**/*.pem
**/*.p8
**/*.key
**/google-application-credentials.json

# Config runtime Firebase Functions
functions/.runtimeconfig.json
firebase/functions/.runtimeconfig.json
backup-functions/.runtimeconfig.json

# Sauvegardes/export locaux éventuels
/backups/
*.backup.json
*.export.json

# ================================
# Logs
# ================================
/logs/
/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
firebase-debug*.log
firestore-debug.log*

# ================================
# Firebase
# ================================
.firebase/            # état local émulateur

# Garder en repo (utile CI/CD & config projet)
!.firebaserc
!firebase.json
!firestore.rules
!storage.rules

# ================================
# Firebase Functions (monorepo sous dossier firebase/)
# ================================
firebase/functions/lib/
firebase/functions/node_modules/
firebase/functions/.env
firebase/functions/.env.*
firebase/functions/backups/
firebase/functions/npm
firebase/functions/*.log

# ================================
# Backup Functions (si présent)
# ================================
backup-functions/lib/
backup-functions/node_modules/
backup-functions/.env
backup-functions/.env.*

# ================================
# Editeurs & OS
# ================================
/.vscode/*
!/.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
desktop.ini
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ================================
# Fichiers temporaires divers
# ================================
**/*.mapbackup
**/*.bak

# ================================
# Firebase config frontend
# ================================
# fichier réel de config Firebase (ne doit pas être versionné)
public/firebase-config.js
# exemple de config Firebase (gardé pour doc)
!public/firebase-config.example.js

# ================================
# Lockfiles (user requested to ignore)
# ================================
/package-lock.json
**/package-lock.json
package-lock.json

# Environment variables - NEVER commit these
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# Firebase
firebase/functions/.env
firebase/functions/.env.development
firebase/functions/.env.production
firebase/functions/.env.local
