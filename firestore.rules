rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ========= UTILITAIRES =========
    function isAuthenticated() { return request.auth != null; }
    function isSignedIn() { return isAuthenticated(); }
    
    function isAdmin() { 
      return request.auth != null && request.auth.token.admin == true; 
    }
    
    function isDev() { 
      return request.auth != null && request.auth.token.dev == true; 
    }
    
    // ✅ ACCÈS ADMIN PAR EMAIL (William)
    function isAdminEmail() {
      return request.auth != null && request.auth.token.email == 'williamsjullin@gmail.com';
    }
    
    function isDocOwner() { return isAuthenticated() && resource.data.uid == request.auth.uid; }
    function creatingOwnDoc() { return isAuthenticated() && request.resource.data.uid == request.auth.uid; }

    function changedKeys() { return request.resource.data.diff(resource.data).changedKeys(); }
    function affectedKeys() { return request.resource.data.diff(resource.data).affectedKeys(); }

    function hasSensitiveChanges() {
      return affectedKeys().hasAny(['role','isAdmin','isApproved','isBanned','uid','type','isVerified','verificationStatus','approvedAt','approvedBy','rejectionReason','reviewedAt','reviewedBy']);
    }
    
    function emailSelfSynced() {
      return changedKeys().hasOnly(['email','emailLower','updatedAt']) && request.resource.data.email == request.auth.token.email && request.resource.data.emailLower == (request.auth.token.email == null ? null : request.auth.token.email.lower());
    }
    
    function presenceKeysOnly() {
      return affectedKeys().hasOnly(['isOnline','availability','lastStatusChange','updatedAt','isVisible','isVisibleOnMap']);
    }

    // ✅ Vérifie si un profil est public (approuvé et visible)
    function isProfilePublic(profile) {
      return profile.data.isApproved == true && profile.data.isVisible == true;
    }

    // =============== USERS ===============
    match /users/{userId} {
      allow read: if (resource.data.role in ['lawyer', 'expat'] && isProfilePublic(resource)) || (isAuthenticated() && request.auth.uid == userId) || isAdmin() || isDev() || isAdminEmail();
      allow create: if (
  isAuthenticated() && 
  request.auth.uid == userId && 
  (
    // Cas 1: CLIENT → peut être auto-approuvé
    (request.resource.data.role == 'client') 
    ||
    // Cas 2: LAWYER/EXPAT → doit être non-approuvé
    (request.resource.data.role in ['lawyer', 'expat'] && 
     request.resource.data.isApproved == false && 
     request.resource.data.isVisible == false && 
     request.resource.data.verificationStatus == 'pending')
  )
) || isAdmin() || isDev() || isAdminEmail();
      allow update: if (isAuthenticated() && request.auth.uid == userId && (emailSelfSynced() || presenceKeysOnly() || !hasSensitiveChanges())) || isAdmin() || isDev() || isAdminEmail();
      allow delete: if isAdmin() || isDev() || isAdminEmail();
    }

 // ====================== SOS_PROFILES ======================
match /sos_profiles/{profileId} {
  // Lecture publique si approuvé et visible, ou si propriétaire, ou si admin
  allow read: if (resource.data.isApproved == true && resource.data.isVisible == true)
                 || (isAuthenticated() && (profileId == request.auth.uid || resource.data.uid == request.auth.uid))
                 || isAdmin() 
                 || isDev() 
                 || isAdminEmail();
  
  // Création uniquement si lawyer/expat et non-approuvé
  allow create: if (isAuthenticated() && request.resource.data.type in ['lawyer','expat'] && request.resource.data.isApproved == false && request.resource.data.isVisible == false && request.resource.data.verificationStatus == 'pending') || isAdmin() || isDev() || isAdminEmail();

  // Fonctions utilitaires pour la validation
  function sosSensitive() {
    return affectedKeys().hasAny(['uid','role','type','isAdmin','isApproved','isBanned','verificationStatus','approvedAt','approvedBy','rejectionReason','reviewedAt','reviewedBy']);
  }
  
  function sosEmailSelfSynced() {
    return changedKeys().hasOnly(['email','emailLower','updatedAt']) && request.resource.data.email == request.auth.token.email && request.resource.data.emailLower == (request.auth.token.email == null ? null : request.auth.token.email.lower());
  }

  // Mise à jour si propriétaire et pas de changements sensibles
  allow update: if (isAuthenticated() && (profileId == request.auth.uid || resource.data.uid == request.auth.uid) && (sosEmailSelfSynced() || presenceKeysOnly() || !sosSensitive())) || isAdmin() || isDev() || isAdminEmail();
  
  // Suppression admin uniquement
  allow delete: if isAdmin() || isDev() || isAdminEmail();
}

    // =============== USERS PRESENCE ===============
    match /usersPresence/{uid} {
      allow read: if true;
      allow create: if (isAuthenticated() && request.auth.uid == uid && request.resource.data.uid == request.auth.uid && presenceKeysOnly()) || isAdmin() || isDev() || isAdminEmail();
      allow update: if (isAuthenticated() && request.auth.uid == uid && presenceKeysOnly()) || isAdmin() || isDev() || isAdminEmail();
      allow delete: if isAdmin() || isDev() || isAdminEmail();
    }

    // ================== PROVIDERS ==================
    match /providers/{providerId} {
      function hasValidProviderFields() {
        return request.resource.data.keys().hasAll(['uid','type','fullName']) && request.resource.data.uid is string && request.resource.data.type in ['lawyer','expat'] && request.resource.data.fullName is string;
      }
      
      allow read: if (resource.data.type in ['lawyer', 'expat'] && isProfilePublic(resource)) || (isAuthenticated() && request.auth.uid == providerId) || isAdmin() || isDev() || isAdminEmail();
      allow create: if ((creatingOwnDoc() && hasValidProviderFields() && request.resource.data.isApproved == false && request.resource.data.isVisible == false && request.resource.data.verificationStatus == 'pending') || isAdmin()) || isDev() || isAdminEmail();
      allow update: if isAdmin() || (isDocOwner() && !affectedKeys().hasAny(['uid','role','email','isAdmin','isApproved','isBanned','type','verificationStatus','approvedAt','approvedBy','rejectionReason','reviewedAt','reviewedBy'])) || isDev() || isAdminEmail();
      allow delete: if isAdmin() || isDev() || isAdminEmail();
    }

    // ------ MESSAGES DANS /providers/{providerId}/messages/{messageId} ------
    match /providers/{providerId}/messages/{messageId} {
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid && request.resource.data.providerId == providerId && request.resource.data.text is string && request.resource.data.text.size() > 0 && request.resource.data.text.size() <= 1000;
      allow read: if isSignedIn() && (providerId == request.auth.uid || resource.data.senderId == request.auth.uid);
      allow update, delete: if false;
    }

    // ========= CALLS =========
    match /calls/{callId} {
      allow read: if (isAuthenticated() && (request.auth.uid == resource.data.clientId || request.auth.uid == resource.data.providerId)) || isAdmin() || isDev() || isAdminEmail();
      allow create, update, delete: if isAdmin() || isDev() || isAdminEmail();
    }

    // ============ PAYMENTS ============
    match /payments/{paymentId} {
      function hasValidPaymentFields() {
        return request.resource.data.keys().hasAll(['clientId','providerId','amount','status']) && request.resource.data.amount is number && request.resource.data.amount > 0 && request.resource.data.status in ['pending','authorized','captured','succeeded','failed','refunded','canceled'];
      }
      allow read: if (isAuthenticated() && (request.auth.uid == resource.data.clientId || request.auth.uid == resource.data.providerId)) || isAdmin() || isDev() || isAdminEmail();
      allow create: if (isAuthenticated() && request.resource.data.clientId == request.auth.uid && hasValidPaymentFields()) || isAdmin() || isDev() || isAdminEmail();
      allow update: if (isAuthenticated() && request.auth.uid == resource.data.clientId) || isAdmin() || isDev() || isAdminEmail();
      allow delete: if isAdmin() || isDev() || isAdminEmail();
    }
    
    match /users/{userId}/payments/{paymentId} {
      allow read: if request.auth.uid == userId || isAdmin() || isDev() || isAdminEmail();
      allow create, update: if (isAuthenticated() && request.auth.uid == userId) || isAdmin() || isDev() || isAdminEmail();
      allow delete: if isAdmin() || isDev() || isAdminEmail();
    }
    
    match /providers/{providerId}/payments/{paymentId} {
      allow read: if request.auth.uid == providerId || isAdmin() || isDev() || isAdminEmail();
      allow create, update: if isAuthenticated() || isAdmin() || isDev() || isAdminEmail();
      allow delete: if isAdmin() || isDev() || isAdminEmail();
    }

    // ============ ORDERS ============
    match /orders/{orderId} {
      allow read: if (isAuthenticated() && (request.auth.uid == resource.data.clientId || request.auth.uid == resource.data.providerId)) || isAdmin() || isDev() || isAdminEmail();
      allow create: if (isAuthenticated() && request.resource.data.clientId == request.auth.uid) || isAdmin() || isDev() || isAdminEmail();
      allow update: if (isAuthenticated() && request.auth.uid == resource.data.clientId) || isAdmin() || isDev() || isAdminEmail();
      allow delete: if isAdmin() || isDev() || isAdminEmail();
    }

    // ========== REVIEWS ==========
    match /reviews/{reviewId} {
      allow read: if resource.data.isPublic == true || resource.data.status == "published" || (isAuthenticated() && (request.auth.uid == resource.data.clientId || request.auth.uid == resource.data.providerId)) || isAdmin() || isDev() || isAdminEmail();
      allow create: if isAuthenticated() && request.resource.data.clientId == request.auth.uid || isDev() || isAdminEmail();
      allow update: if (isAuthenticated() && request.auth.uid == resource.data.clientId && !affectedKeys().hasAny(['clientId','providerId','isPublic','status'])) || isAdmin() || isDev() || isAdminEmail();
      allow delete: if (isAuthenticated() && request.auth.uid == resource.data.clientId) || isAdmin() || isDev() || isAdminEmail();
    }
    
    match /providerReviews/{reviewId} {
      allow read: if resource.data.isPublic == true || resource.data.status == "published" || (isAuthenticated() && (request.auth.uid == resource.data.clientId || request.auth.uid == resource.data.providerId)) || isAdmin() || isDev() || isAdminEmail();
      allow create: if isAuthenticated() && request.resource.data.clientId == request.auth.uid || isDev() || isAdminEmail();
      allow update: if (isAuthenticated() && request.auth.uid == resource.data.clientId && !affectedKeys().hasAny(['clientId','providerId','isPublic','status'])) || isAdmin() || isDev() || isAdminEmail();
      allow delete: if (isAuthenticated() && request.auth.uid == resource.data.clientId) || isAdmin() || isDev() || isAdminEmail();
    }

    // ============ BOOKING_REQUESTS ============
    match /booking_requests/{bookingId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.clientId || request.auth.uid == resource.data.providerId) || isAdmin() || isDev() || isAdminEmail();
      allow create: if isAuthenticated() && request.resource.data.clientId == request.auth.uid && request.resource.data.status == "pending" || isDev() || isAdminEmail();
      allow update: if false;
      allow delete: if isAdmin() || isDev() || isAdminEmail();
    }

    // ============ DOCUMENTS ============
    match /documents/{documentId} {
      allow read: if (isAuthenticated() && request.auth.uid == resource.data.userId) || isAdmin() || isDev() || isAdminEmail();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid || isDev() || isAdminEmail();
      allow update: if isAdmin() || isDev() || isAdminEmail();
      allow delete: if (isAuthenticated() && request.auth.uid == resource.data.userId) || isAdmin() || isDev() || isAdminEmail();
    }

    // =============== NOTIFICATIONS ===============
    match /notifications/{notificationId} {
      allow read: if (isAuthenticated() && request.auth.uid == resource.data.userId) || isAdmin() || isDev() || isAdminEmail();
      allow create: if isAdmin() || isDev() || isAdminEmail();
      allow update: if (isAuthenticated() && request.auth.uid == resource.data.userId) || isAdmin() || isDev() || isAdminEmail();
      allow delete: if (isAuthenticated() && request.auth.uid == resource.data.userId) || isAdmin() || isDev() || isAdminEmail();
    }

    // ================= CALL_SESSIONS =================
    match /call_sessions/{sessionId} {
      allow read: if (isAuthenticated() && (request.auth.uid == resource.data.metadata.clientId || request.auth.uid == resource.data.metadata.providerId)) || isAdmin() || isDev() || isAdminEmail();
      allow create, update, delete: if isAdmin() || isDev() || isAdminEmail();
    }
    
    match /callSessions/{sessionId} {
      allow read: if (isAuthenticated() && (request.auth.uid == resource.data.metadata.clientId || request.auth.uid == resource.data.metadata.providerId)) || isAdmin() || isDev() || isAdminEmail();
      allow create, update, delete: if isAdmin() || isDev() || isAdminEmail();
    }

    // ================== INVOICE_RECORDS ==================
    match /invoice_records/{invoiceId} {
      allow read: if (isAuthenticated() && (request.auth.uid == resource.data.clientId || request.auth.uid == resource.data.providerId)) || isAdmin() || isDev() || isAdminEmail();
      allow create, update, delete: if isAdmin() || isDev() || isAdminEmail();
    }

    // ================== TRANSFERS ==================
    match /transfers/{transferId} {
      allow read: if (isAuthenticated() && request.auth.uid == resource.data.providerId) || isAdmin() || isDev() || isAdminEmail();
      allow create, update, delete: if isAdmin() || isDev() || isAdminEmail();
    }

    // ================== PENDING TRANSFERS ==================
    match /pending_transfers/{transferId} {
      allow read: if (isAuthenticated() && request.auth.uid == resource.data.providerId) || isAdmin() || isDev() || isAdminEmail();
      allow create, update, delete: if isAdmin() || isDev() || isAdminEmail();
    }

    // =================== NOTIFICATION_LOGS ===================
    match /notification_logs/{logId} {
      allow read: if (isAuthenticated() && request.auth.uid == resource.data.recipientId) || isAdmin() || isDev() || isAdminEmail();
      allow create: if isAuthenticated() || isDev() || isAdminEmail();
      allow update, delete: if isAdmin() || isDev() || isAdminEmail();
    }

    // ================= MESSAGING SYSTEM =================
    match /message_templates/{locale}/items/{eventId} {
      allow read, write: if isAdmin() || isDev() || isAdminEmail();
    }
    
    match /message_routing/{docId} {
      allow read, write: if isAdmin() || isDev() || isAdminEmail();
    }
    
    match /message_events/{id} {
      allow create: if isAuthenticated() && request.resource.data.createdBy == request.auth.uid;
      allow read: if isAdmin() || isDev() || isAdminEmail();
      allow update, delete: if false;
    }
    
    match /message_deliveries/{id} {
      allow read: if isAdmin() || isDev() || isAdminEmail();
      allow write: if false;
    }

    // ================= ADMIN Collections =================
    match /logs/{logId} { 
      allow create: if true; 
      allow read, update, delete: if isAdmin() || isDev() || isAdminEmail(); 
    }

    match /analytics/{analyticsId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin() || isDev() || isAdminEmail();
    }
    
    match /analytics_errors/{id} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin() || isDev() || isAdminEmail();
    }

    match /app_settings/{settingId} { allow read, write: if isAdmin() || isDev() || isAdminEmail(); }
    match /admin_settings/{settingId} { allow read, write: if isAdmin() || isDev() || isAdminEmail(); }
    match /backups/{backupId} { allow read, write: if isAdmin() || isDev() || isAdminEmail(); }

    match /contact_messages/{messageId} {
      allow read: if isAdmin() || isDev() || isAdminEmail();
      allow create: if true;
      allow update, delete: if isAdmin() || isDev() || isAdminEmail();
    }

    match /legal_documents/{docId} {
      allow read: if true;
      allow write: if isAdmin() || isDev() || isAdminEmail();
    }

    match /coupons/{couponId} {
      allow read: if resource.data.active == true || isAdmin() || isDev() || isAdminEmail();
      allow write: if isAdmin() || isDev() || isAdminEmail();
    }

    match /coupon_usages/{usageId} {
      allow read: if (isAuthenticated() && request.auth.uid == resource.data.userId) || isAdmin() || isDev() || isAdminEmail();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid || isDev() || isAdminEmail();
      allow update, delete: if isAdmin() || isDev() || isAdminEmail();
    }

    match /admin_config/{docId} {
      allow read: if true;
      allow write: if isAdmin() || isDev() || isAdminEmail();
    }
    
    match /config/{docId} {
      allow read: if isAdmin() || isDev() || isAdminEmail();
      allow write: if isAdmin() || isDev() || isAdminEmail();
    }

    // ================= PROVIDER MESSAGE ORDER CUSTOMERS =================
    match /providerMessageOrderCustomers/{messageId} {
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid && request.resource.data.providerId is string && request.resource.data.message is string && request.resource.data.message.size() > 0 && request.resource.data.message.size() <= 1000;
      allow read: if (isAuthenticated() && (request.auth.uid == resource.data.providerId || request.auth.uid == resource.data.senderId)) || isAdmin() || isDev() || isAdminEmail();
      allow update: if isAuthenticated() && request.auth.uid == resource.data.providerId && request.resource.data.diff(resource.data).changedKeys().hasOnly(['isRead']);
      allow delete: if isAdmin() || isDev() || isAdminEmail();
    }

    // ======================= Catch-all =======================
    match /{document=**} { allow read, write: if false || isDev() || isAdminEmail(); }
  }
}